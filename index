              {act.etapes&&<div style={{display:"flex",flexDirection:"column",gap:8}}>{act.etapes.map((e,i)=>(
                <div key={i} style={{display:"flex",gap:10,alignItems:"flex-start"}}>
                  <div style={{background:li.color,color:"#fff",borderRadius:"50%",width:26,height:26,display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:900,flexShrink:0,marginTop:1}}>{i+1}</div>
                  <p style={{margin:0,color:"#333",fontSize:14,lineHeight:1.55}}>{e}</p>
                </div>
              ))}</div>}
            </div>
            {/* Variante */}
            <div style={{background:"#fdf0ff",borderRadius:16,padding:"13px 15px",marginBottom:12}}>
              <p style={{margin:"0 0 5px",fontWeight:800,fontSize:14,color:"#888"}}>✨ Variante</p>
              <p style={{margin:0,color:"#5a2a7a",fontSize:14,lineHeight:1.55}}>{act.variante}</p>
            </div>
            {/* Sécurité */}
            <div style={{background:"#fff3cd",borderRadius:16,padding:"13px 16px",border:"2px solid #ffc107",marginBottom:20}}>
              <p style={{margin:0,fontWeight:800,fontSize:14,color:"#856404"}}>⚠️ Sécurité</p>
              <p style={{margin:"6px 0 0",color:"#6b5019",fontSize:14,lineHeight:1.55}}>{act.securite}</p>
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:10}}>
              <button onClick={()=>{setStep("list");playBack();}} style={{padding:16,background:li.color,color:"#fff",border:"none",borderRadius:20,fontSize:17,fontWeight:900,cursor:"pointer",boxShadow:`0 5px 18px ${li.color}50`}}>← Retour aux aventures</button>
              {next&&<button onClick={()=>open(next)} style={{padding:"13px 16px",background:"#fff",color:li.color,border:`2.5px solid ${li.color}`,borderRadius:18,fontSize:15,fontWeight:800,cursor:"pointer"}}>➡️ Aventure suivante</button>}
            </div>
          </div>
        </div>
      </div>
    );
  }

  // LIST
  if(step==="list"&&lieuInfo){
    const li=lieuInfo;
    return(
      <div style={{minHeight:"100vh",background:`linear-gradient(150deg,${li.bg} 0%,#fff 100%)`,fontFamily:"Nunito,sans-serif"}}>
        <style>{CSS}</style><FloatingBg/>
        {slot&&<Slot pool={lieuPool} onSelect={slotOk} onClose={()=>setSlot(false)}/>}
        <div style={{position:"relative",zIndex:1}}>
          <div style={{background:li.color,padding:"16px 20px",display:"flex",alignItems:"center",gap:12,boxShadow:`0 4px 20px ${li.color}55`}}>
            <button onClick={()=>{setStep("home");setLieu(null);setIntens(null);playBack();}} style={{background:"rgba(255,255,255,0.25)",border:"none",borderRadius:12,padding:"6px 16px",color:"#fff",fontSize:20,cursor:"pointer",fontWeight:900}}>←</button>
            <span style={{color:"#fff",fontWeight:900,fontSize:20,flex:1}}>{li.emoji} {li.label}</span>
            <div style={{fontSize:38,animation:`${li.anim} ${li.dur} ease-in-out infinite`}}>{li.obj}</div>
          </div>
          <div style={{padding:"16px",maxWidth:500,margin:"0 auto"}}>
            <div style={{display:"flex",gap:10,marginBottom:16}}>
              <button onClick={()=>setSlot(true)} style={{flex:1,padding:"14px 10px",background:"linear-gradient(135deg,#e25822,#ff8c42)",color:"#fff",border:"none",borderRadius:18,fontSize:14,fontWeight:900,cursor:"pointer",boxShadow:"0 4px 18px rgba(226,88,34,0.4)",animation:"pulse 2.2s ease infinite"}}>🎲 Aventure surprise !</button>

            </div>
            <div style={{background:"#fff",borderRadius:18,padding:"14px",marginBottom:16,boxShadow:"0 2px 14px rgba(0,0,0,0.06)"}}>
              <p style={{margin:"0 0 10px",fontWeight:900,color:"#666",fontSize:14}}>💪 Intensité</p>
              <div style={{display:"flex",gap:8}}>{avail.map(i=>(
                <button key={i.key} onClick={()=>pick(i.key)} style={{flex:1,padding:"11px 6px",borderRadius:14,border:"2.5px solid",borderColor:intens===i.key?i.color:"#eee",background:intens===i.key?i.color:"#fafafa",color:intens===i.key?"#fff":"#555",fontFamily:"Nunito,sans-serif",fontSize:14,fontWeight:800,cursor:"pointer",transition:"all 0.2s"}}>{i.emoji} {i.key}</button>
              ))}</div>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
              <p style={{margin:0,fontWeight:900,color:li.color,fontSize:15}}>{filtered.length} aventure{filtered.length>1?"s":""} 🎯</p>
              {intens&&<button onClick={()=>pick(intens)} style={{background:"none",border:`1.5px solid ${li.color}`,borderRadius:12,padding:"4px 12px",color:li.color,fontWeight:700,fontSize:13,cursor:"pointer"}}>Tout voir</button>}
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:12,paddingBottom:36}}>
              {filtered.length===0?<div style={{textAlign:"center",padding:"48px 20px",color:"#bbb"}}><div style={{fontSize:48}}>🤔</div><p style={{fontWeight:700,fontSize:16}}>Aucune aventure ici…</p></div>
              :filtered.map((a,i)=>{
                const ii=INTENSITES.find(x=>x.key===getIntens(a));const oe=getEmoji(a.objectif);
                return(
                  <div key={a.id} onClick={()=>open(a)} style={{background:"#fff",borderRadius:22,padding:"16px 18px",boxShadow:`0 3px 18px ${li.color}15`,borderLeft:`5px solid ${ii.color}`,cursor:"pointer",opacity:ready?1:0,transform:ready?"translateY(0) scale(1)":"translateY(28px) scale(0.96)",transition:`opacity 0.38s ${i*0.055}s, transform 0.38s ${i*0.055}s`}}
                    onMouseEnter={e=>{e.currentTarget.style.transform="scale(1.02)";e.currentTarget.style.boxShadow=`0 8px 28px ${li.color}30`;}}
                    onMouseLeave={e=>{e.currentTarget.style.transform="scale(1)";e.currentTarget.style.boxShadow=`0 3px 18px ${li.color}15`;}}>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",gap:10}}>
                      <div style={{flex:1}}>
                        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:5}}>
                          <span style={{fontSize:24}}>{oe}</span>
                          <h3 style={{margin:0,color:"#333",fontSize:16,fontWeight:900,lineHeight:1.2}}>{a.titre}</h3>
                        </div>
                        <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                          <Chip bg="#f0fff4" c="#2d7a2d" text={`⏱️ ${a.duree}`}/>
                          <Chip bg={li.bg} c={li.color} text={`${ii.emoji} ${ii.key}`}/>
                          <Chip bg="#f5f5f5" c="#888" text={`👥 ${a.nbJ}`}/>
                        </div>
                        <p style={{margin:"7px 0 0",color:"#bbb",fontSize:13,fontWeight:600}}>🎒 {a.materiel}</p>
                      </div>
                      <div style={{background:li.color,borderRadius:14,padding:"11px 15px",color:"#fff",fontWeight:900,fontSize:15,flexShrink:0,boxShadow:`0 3px 10px ${li.color}45`}}>Voir →</div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    );
  }

  // HOME
  return(
    <div style={{minHeight:"100vh",background:"linear-gradient(160deg,#fff9f2 0%,#fde8d8 55%,#e8f4ff 100%)",fontFamily:"Nunito,sans-serif",overflow:"hidden"}}>
      <style>{CSS}</style><FloatingBg/>
      {slot&&<Slot pool={ACTIVITIES} onSelect={slotOk} onClose={()=>setSlot(false)}/>}
      <div style={{position:"relative",zIndex:1}}>
        <div style={{width:"100%",lineHeight:0,background:"#c8f0ff"}}>
          <img src={HERO} alt="Ti pa-Ti pa" style={{width:"100%",display:"block",objectFit:"contain",objectPosition:"top"}}/>
        </div>
        <div style={{padding:"20px 16px 0",maxWidth:500,margin:"0 auto"}}>
          <p style={{textAlign:"center",fontWeight:900,fontSize:17,color:"#555",margin:"0 0 20px",lineHeight:1.5}}>Choisissez un lieu pour commencer ! 🌟</p>
          <button onClick={()=>setSlot(true)} style={{width:"100%",padding:"17px",marginBottom:22,background:"linear-gradient(135deg,#e25822,#ff8c42)",color:"#fff",border:"none",borderRadius:22,fontSize:19,fontWeight:900,cursor:"pointer",boxShadow:"0 6px 22px rgba(226,88,34,0.42)",animation:"pulse 2.5s ease infinite",display:"flex",alignItems:"center",justifyContent:"center",gap:12}}>
            <span style={{fontSize:28}}>🎲</span> Aventure surprise !
          </button>
          <p style={{textAlign:"center",fontWeight:800,color:"#bbb",fontSize:14,marginBottom:14}}>— ou choisissez un lieu —</p>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14}}>
            {LIEUX.map((l,i)=>{
              const isAnim=tileAnim===l.key;
              return(
                <button key={l.key} onClick={()=>goLieu(l)} style={{background:isAnim?l.color:l.bg,border:`3px solid ${l.color}`,borderRadius:24,padding:"22px 10px",cursor:"pointer",textAlign:"center",boxShadow:isAnim?`0 12px 32px ${l.color}70`:`0 5px 18px ${l.color}25`,fontFamily:"Nunito,sans-serif",animation:`cardBounceIn 0.5s cubic-bezier(0.34,1.56,0.64,1) ${i*0.09}s both`,transform:isAnim?"scale(1.08)":"scale(1)",transition:"transform 0.2s,box-shadow 0.2s,background 0.2s"}}>
                  <div style={{fontSize:40,marginBottom:6}}>{l.emoji}</div>
                  <div style={{fontWeight:900,fontSize:16,color:isAnim?"#fff":l.color}}>{l.label}</div>
                  <div style={{fontSize:11,color:isAnim?"rgba(255,255,255,0.8)":"#bbb",marginTop:4,fontWeight:600}}>{ACTIVITIES.filter(a=>getLieu(a)===l.key).length} aventures</div>
                </button>
              );
            })}
          </div>

        </div>
      </div>
    </div>
  );
}

const CSS=`
*{box-sizing:border-box;}
@keyframes floatDrift{from{transform:translateY(0) rotate(-4deg)}to{transform:translateY(-22px) rotate(6deg)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.035)}}
@keyframes slotSpin{from{transform:translateY(-5px)}to{transform:translateY(5px)}}
@keyframes cardBounceIn{from{opacity:0;transform:translateY(32px) scale(0.88)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes slideUp{from{opacity:0;transform:translateY(44px)}to{opacity:1;transform:translateY(0)}}
@keyframes popIn{from{transform:scale(0.6);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes maisonBounce{0%,100%{transform:translateY(0) rotate(-5deg)}40%{transform:translateY(-14px) rotate(5deg)}}
@keyframes ballRoll{0%{transform:translateX(-10px) rotate(0deg)}50%{transform:translateX(10px) rotate(180deg)}100%{transform:translateX(-10px) rotate(360deg)}}
@keyframes bubbleFloat{0%{transform:translateY(0) scale(1);opacity:0.9}30%{transform:translateY(-18px) scale(1.08);opacity:1}100%{transform:translateY(0) scale(1);opacity:0.9}}
@keyframes beachBounce{0%,100%{transform:translateY(0) scaleY(1)}40%{transform:translateY(-18px) scaleY(1.05)}}
@keyframes shoeJump{0%,100%{transform:translateY(0) rotate(0deg)}35%{transform:translateY(-20px) rotate(-15deg)}}
@keyframes trophyBounce{0%,100%{transform:translateY(0) scale(1)}40%{transform:translateY(-16px) scale(1.15)}}
`;
const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(React.createElement(App));
</script>

