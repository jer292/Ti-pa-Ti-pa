  {id:"TP037",titre:"Feu rouge feu vert",lieu:"Parc",duree:"10-15 min",intensite:"Modérée",objectif:"contrôle moteur, réaction",materiel:"aucun",nbJ:"2-6",consigne:"Le code couleur de la route, version sport !",etapes:["Un joueur est le feu","Vert = courir vers lui","Orange = marcher","Rouge = statue immobile","Bleu = sauter sur place","Violet = tourner en rond"],variante:"Accélérer les annonces de couleurs pour rendre le jeu plus dynamique.",benefice:"Développe la réactivité et le contrôle du corps.",securite:"Rester dans la zone visible."},
  {id:"TP043",titre:"Marelle au sol",lieu:"Parc",duree:"10-15 min",intensite:"Modérée",objectif:"saut, équilibre",materiel:"craie ou bâton",nbJ:"1-4",consigne:"Le classique de tous les enfants du monde — dessiné par vous !",etapes:["Dessinez une marelle au sol (cases 1 à 9)","Lancez un caillou dans la case 1","Sautez toutes les cases sans toucher la case du caillou","Ramassez le caillou en chemin et recommencez avec la case 2 !"],variante:"Pour les plus jeunes : sauter juste sans lancer de caillou.",benefice:"Renforce l\'équilibre, le saut et la numération.",securite:"Rester dans la zone visible."},
  {id:"TP044",titre:"Attrape-bulles",lieu:"Parc",duree:"10-15 min",intensite:"Modérée",objectif:"saut, coordination",materiel:"bulles de savon",nbJ:"1-4",consigne:"Attrapez les bulles avant qu\'elles ne touchent le sol !",etapes:["Un joueur fait des bulles de savon","Les autres essaient de les éclater avant qu\'elles touchent le sol","Utilisez la main, le pied, le coude, la tête…","Comptez combien de bulles vous éclatez en 1 minute !"],variante:"Faire des grosses bulles hautes puis des petites bulles basses.",benefice:"Développe la coordination et les réflexes de façon magique.",securite:"Rester dans la zone visible."},
  {id:"TP048",titre:"Relais parent-enfant",lieu:"Parc",duree:"10-15 min",intensite:"Modérée",objectif:"coopération, course",materiel:"objet léger",nbJ:"2-4",consigne:"On se passe le témoin et on court ! Ensemble on va plus loin.",etapes:["Tracez 2 lignes espacées de 10 mètres","Un joueur attend à chaque ligne","Le premier court et passe l\'objet au second","Le second court et le repasse","Continuez en faisant des allers-retours !"],variante:"Transporter l\'objet sur la tête, sous le menton, ou entre les genoux.",benefice:"Développe la coopération, la course et la coordination.",securite:"Rester dans la zone visible."},
  {id:"TPN10",titre:"Le jeu du loup des mangroves",lieu:"Parc",duree:"10-15 min",intensite:"Dynamique",objectif:"course, stratégie, agilité",materiel:"aucun",nbJ:"3-6",consigne:"Le loup des mangroves chasse ! Qui sera attrapé le dernier ?",etapes:["Un joueur est désigné loup","Au signal, le loup court pour attraper les autres","Quand il touche quelqu\'un, ce joueur devient loup à son tour","On s\'arrête pour souffler toutes les 2 minutes"],variante:"Zone de sécurité : les joueurs touchant un arbre sont intouchables pendant 5 secondes.",benefice:"Développe la vitesse, la stratégie et l\'endurance.",securite:"Délimiter la zone de jeu, terrain plat."},
  {id:"TPN11",titre:"Mini-olympiades du parc",lieu:"Parc",duree:"20-30 min",intensite:"Dynamique",objectif:"motricité globale, coopération",materiel:"aucun",nbJ:"2-6",consigne:"5 épreuves olympiques improvisées avec ce que vous avez sous la main !",etapes:["Épreuve 1 : Course jusqu\'à l\'arbre","Épreuve 2 : Saut en longueur depuis une ligne","Épreuve 3 : Lancer d\'une pomme de pin dans un cercle","Épreuve 4 : Équilibre sur un pied (qui tient le plus longtemps ?)","Épreuve 5 : Ramper sous le banc le plus vite possible"],variante:"Chaque enfant invente une 6e épreuve surprise !",benefice:"Variété d\'habiletés motrices en un seul jeu festif.",securite:"Surveiller les structures, terrain plat pour les courses."},
  {id:"TP052",titre:"Course dans le sable",lieu:"Plage",duree:"10-20 min",intensite:"Dynamique",objectif:"courir, endurance",materiel:"aucun",nbJ:"1-4",consigne:"Courir dans le sable, c\'est 2x plus dur et 10x plus drôle !",etapes:["Tracez deux lignes dans le sable (départ et arrivée)","Courez entre les lignes","Comparez : sable sec, puis sable humide","Quel sable est le plus difficile ?"],variante:"Course à reculons ou en crabe (de côté) aussi !",benefice:"Renforce les chevilles et les jambes, travaille l\'endurance.",securite:"Éviter les heures chaudes."},
  {id:"TP053",titre:"Château de sable actif",lieu:"Plage",duree:"10-20 min",intensite:"Modérée",objectif:"coopération, motricité fine",materiel:"seau, pelle",nbJ:"2-5",consigne:"Construction en équipe ! Chacun a un rôle dans le chantier.",etapes:["Attribuez les rôles : architecte, creuseur, transporteur d\'eau","L\'architecte trace le plan au sol avec un bâton","Les autres construisent selon le plan","Décorez avec des coquillages en faisant des allers-retours pour les ramasser"],variante:"Construire le château le plus haut possible ou le plus proche de l\'eau.",benefice:"Développe la coopération, la planification et la motricité fine.",securite:"Éviter les heures chaudes."},
  {id:"TP056",titre:"Vagues et statues",lieu:"Plage",duree:"10-20 min",intensite:"Modérée",objectif:"réaction, agilité",materiel:"aucun",nbJ:"2-6",consigne:"La vague arrive ! Fuyez ou avancez selon le signal !",etapes:["Les joueurs se tiennent face à la mer à distance sécurisée","Vague ! = reculez vite","Calme ! = avancez vers l\'eau","Tempête ! = courez latéralement","Réagissez le plus vite possible !"],variante:"Associer une couleur à chaque mouvement pour varier.",benefice:"Développe la réactivité et le plaisir du mouvement au bord de l\'eau.",securite:"Rester à distance sécurisée de l\'eau."},
  {id:"TP058",titre:"Sprint vague",lieu:"Plage",duree:"10-20 min",intensite:"Dynamique",objectif:"courir, réactivité",materiel:"aucun",nbJ:"1-4",consigne:"Courez vers la vague et reculez avant qu\'elle vous mouille les pieds !",etapes:["Attendez une vague au bord de l\'eau","Courez vers elle quand elle arrive","Reculez VITE avant qu\'elle touche vos pieds","Comptez combien de fois vous réussissez !"],variante:"Voir qui peut rester le plus proche de la vague sans se faire mouiller.",benefice:"Développe la vitesse de réaction et la coordination.",securite:"Surveiller l\'espace, zone peu profonde uniquement."},
  {id:"TP059",titre:"Lancer de galets doux",lieu:"Plage",duree:"10-20 min",intensite:"Calme",objectif:"lancer, viser",materiel:"petits galets plats",nbJ:"1-4",consigne:"Faites des ricochets ! Un galet bien lancé peut rebondir 5 fois sur l\'eau.",etapes:["Ramassez des galets plats et ronds","Penchez-vous légèrement, tenez le galet à plat","Lancez de côté, près de la surface de l\'eau","Comptez les rebonds !"],variante:"Comparer les galets : lesquels font le plus de ricochets ? Pourquoi ?",benefice:"Développe la précision du lancer et la curiosité scientifique.",securite:"Vérifier qu\'il n\'y a personne dans la trajectoire."},
  {id:"TP060",titre:"Mini-olympiade plage",lieu:"Plage",duree:"20-30 min",intensite:"Dynamique",objectif:"motricité globale",materiel:"seau, balle, ligne tracée",nbJ:"2-6",consigne:"5 épreuves, 1 médaille de champion de la plage !",etapes:["Épreuve 1 : Course dans le sable (30 mètres)","Épreuve 2 : Saut en longueur depuis une ligne tracée","Épreuve 3 : Lancer de galet le plus loin possible","Épreuve 4 : Équilibre sur un pied dans le sable","Épreuve 5 : Transport d\'eau dans un seau sans en renverser"],variante:"Chaque famille invente une 6e épreuve surprise.",benefice:"Variété de compétences motrices dans un format festif.",securite:"Éviter les heures chaudes."},
  {id:"TP061",titre:"Parcours naturel",lieu:"Extérieur",duree:"20-30 min",intensite:"Dynamique",objectif:"motricité globale",materiel:"aucun",nbJ:"1-4",consigne:"La nature est votre terrain de jeu ! Utilisez tout ce qui vous entoure.",etapes:["Repérez 5 obstacles naturels : branche à enjamber, muret bas, 3 arbres à contourner…","Expliquez le parcours","Chacun le fait à son rythme","Inventez une histoire : on est des explorateurs !"],variante:"Inventer ensemble une histoire qui justifie chaque obstacle.",benefice:"Développe la motricité globale en explorant l\'environnement naturel.",securite:"Surveiller les surfaces, pas de hauteur."},
  {id:"TP062",titre:"Balade sensorielle",lieu:"Extérieur",duree:"20-30 min",intensite:"Calme",objectif:"observation, marche",materiel:"aucun",nbJ:"1-4",consigne:"Marchez en silence et cherchez 1 chose à voir, entendre, toucher et sentir.",etapes:["Marchez doucement en silence sur 100 mètres","Cherchez quelque chose d\'intéressant à voir","Écoutez attentivement : qu\'entendez-vous ?","Touchez l\'écorce d\'un arbre, une feuille…","Humez l\'air : quelles odeurs reconnaissez-vous ?"],variante:"Chacun partage sa découverte favorite à la fin de la balade.",benefice:"Développe l\'attention, la curiosité et la connexion à la nature.",securite:"Surveiller les surfaces."},
  {id:"TP063",titre:"Défi marche animale",lieu:"Extérieur",duree:"20-30 min",intensite:"Modérée",objectif:"motricité, imagination",materiel:"aucun",nbJ:"1-4",consigne:"Transformez votre balade en défilé d\'animaux !",etapes:["Le parent annonce un animal toutes les 2 minutes","Canard = marcher accroupi","Crabe = de côté","Géant = grands pas lents","Bébé = tout petits pas"],variante:"L\'enfant choisit l\'animal et imite, le parent devine.",benefice:"Rend la balade active et imaginative.",securite:"Surveiller les surfaces."},
  {id:"GJ001",titre:"1, 2, 3 Soleil !",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"contrôle moteur, réaction, stratégie",materiel:"aucun",nbJ:"4-15",consigne:"Avancez en douce vers le soleil… mais ne bougez plus quand il se retourne !",etapes:["Un joueur est le Soleil : il se place dos aux autres, face à un mur","Les autres joueurs se tiennent à 10 mètres derrière lui","Le Soleil dit 1, 2, 3 Soleil ! en se retournant rapidement","Pendant qu\'il parle, les joueurs avancent vers lui","Quand il se retourne, tout le monde se fige","Celui qu\'il voit bouger retourne au départ","Le premier à toucher le Soleil dans le dos a gagné !"],variante:"Le Soleil peut varier la vitesse de sa phrase pour piéger les joueurs. Version péi : dire 1, 2, 3 Volcan !",benefice:"Développe le contrôle moteur, l\'inhibition et la stratégie dès 3 ans.",securite:"Terrain plat, délimiter l\'espace."},
  {id:"GJ002",titre:"L\'épervier",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, vitesse, stratégie",materiel:"aucun",nbJ:"6-20",consigne:"L\'épervier chasse ! Traversez sa zone sans vous faire attraper.",etapes:["Un joueur est l\'épervier : il se place au milieu d\'un terrain","Les autres joueurs se tiennent sur une ligne de départ","Au signal, tous doivent traverser le terrain jusqu\'à l\'autre côté","L\'épervier essaie de toucher un maximum de joueurs","Les joueurs touchés deviennent éperviers à leur tour","Continuez jusqu\'à ce qu\'il ne reste plus qu\'un joueur libre"],variante:"Les éperviers se tiennent par la main pour former un filet — plus difficile à traverser !",benefice:"Développe la vitesse, la stratégie de course et la réactivité.",securite:"Délimiter clairement le terrain, terrain plat sans obstacle."},
  {id:"GJ003",titre:"Le magicien pétrifié",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, coopération, agilité",materiel:"aucun",nbJ:"5-15",consigne:"Le magicien pétrifie tout le monde ! Mais un sauveur peut tout annuler…",etapes:["Un joueur est le magicien","Quand il touche quelqu\'un, ce joueur reste figé sur place","Pour être libéré, un autre joueur doit ramper entre ses jambes","Le magicien essaie de pétrifier TOUT le monde","S\'il n\'y arrive pas seul, il peut se choisir un assistant","Le dernier non pétrifié devient le nouveau magicien"],variante:"Le sauveur doit dire une formule magique en libérant quelqu\'un : Alakazam péi !",benefice:"Développe la coopération, la course et le geste de ramper en situation de jeu.",securite:"Terrain plat, délimiter l\'espace, surveiller les chutes."},
  {id:"GJ004",titre:"Le grand serpent",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"coopération, coordination, lien social",materiel:"aucun",nbJ:"4-12",consigne:"Formez le plus grand serpent du monde… sans vous décrocher !",etapes:["Un enfant est la tête du serpent","Il se place devant un autre assis et dit : Je suis le grand serpent, veux-tu faire un bout de ma queue ?","L\'enfant passe entre les jambes du serpent et s\'accroche derrière","Le serpent se déplace dans l\'espace en transportant sa queue","Continuez jusqu\'à ce que tout le monde soit dans le serpent","Déplacez le serpent en courant doucement, puis en zigzag !"],variante:"Le serpent doit franchir des obstacles (passer sous une corde, contourner des arbres) sans se décrocher.",benefice:"Développe la coopération, la coordination et le lien social de façon joyeuse.",securite:"Déplacements doux, surveiller que le serpent ne tire pas trop fort."},
  {id:"GJ005",titre:"La chenille géante",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"coopération, écoute, coordination",materiel:"aucun",nbJ:"4-15",consigne:"Formez une chenille vivante et réagissez tous ensemble aux signaux !",etapes:["Les joueurs forment une file indienne, mains sur les épaules du voisin","La chenille se déplace ensemble au rythme du chef (l\'adulte)","Signal Feuille ! = la chenille accélère","Signal Oiseau ! = la chenille s\'accroupit en avançant","Signal Pluie ! = la chenille ralentit et se serre","Signal Soleil ! = la chenille s\'étire les bras au ciel"],variante:"La chenille doit franchir des obstacles (slalom autour d\'arbres, passer sous une corde) sans se décrocher.",benefice:"Développe l\'écoute, la coopération et la coordination de groupe.",securite:"Déplacements doux, éviter de tirer ou pousser."},
  {id:"GJ006",titre:"Chat et souris",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, réaction, stratégie",materiel:"aucun",nbJ:"5-15",consigne:"Les souris fuient le chat ! Mais quand le chat change, tout le monde change !",etapes:["Un joueur est le chat, les autres sont des souris","Le chat doit toucher une souris","Quand il touche quelqu\'un, ce joueur devient chat à son tour","L\'ancien chat devient souris","Le jeu ne s\'arrête jamais — tout le monde court tout le temps !"],variante:"Ajouter des zones de refuge (toucher un arbre = intouchable 5 secondes maximum).",benefice:"Développe la vitesse de course, la réactivité et la stratégie de fuite.",securite:"Délimiter clairement le terrain, terrain plat sans obstacle."},
  {id:"GJ007",titre:"Les lapins dans leur terrier",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, réaction, coopération",materiel:"cerceaux ou zones tracées au sol",nbJ:"6-15",consigne:"Chaque lapin a un terrier… mais il n\'y a pas assez de terriers pour tout le monde !",etapes:["Tracez des cercles au sol (1 de moins que le nombre de joueurs)","Chaque joueur est dans un terrier sauf un — c\'est le lapin sans maison","Au signal, TOUS les lapins changent de terrier en courant","Le lapin sans maison essaie d\'en trouver une","Celui qui se retrouve sans terrier est le prochain lapin sans maison"],variante:"L\'adulte peut retirer un terrier de plus pour pimenter le jeu.",benefice:"Développe la vitesse de réaction et l\'anticipation spatiale.",securite:"Terrain plat, cerceaux bien posés à plat."},
  {id:"GJ008",titre:"Le passage de la rivière",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"saut, coopération, stratégie",materiel:"2 cordes ou lignes tracées au sol",nbJ:"4-15",consigne:"La rivière est pleine de crocodiles ! Traversez-la sans tomber à l\'eau.",etapes:["Tracez 2 lignes parallèles au sol (la rivière) espacées de 1 à 2 mètres","Des joueurs sont les crocodiles : ils restent dans la rivière","Les autres doivent traverser la rivière de l\'autre côté","Si un crocodile touche un joueur dans la rivière, celui-ci devient crocodile","Gagnez en atteignant l\'autre rive sans vous faire toucher"],variante:"Poser des pierres (serviettes ou feuilles) dans la rivière pour aider les joueurs à traverser en sautant.",benefice:"Développe le saut, la stratégie et la coopération pour aider les plus petits.",securite:"Terrain plat, surveiller les chutes lors des sauts."},
  {id:"GJ009",titre:"Vider sa caisse, remplir sa caisse",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, coopération, stratégie d\'équipe",materiel:"balles molles ou chaussettes roulées, 2 caisses",nbJ:"6-20",consigne:"Deux équipes, deux camps. L\'équipe qui a le moins d\'objets dans son camp à la fin a gagné !",etapes:["Divisez le terrain en 2 camps avec une ligne centrale","Placez autant d\'objets (balles molles, chaussettes) dans chaque camp","Au signal, chaque équipe lance ses objets dans le camp adverse","On ne peut lancer qu\'un objet à la fois","On ne peut pas bloquer les objets avec son corps","Au signal de fin, on compte : l\'équipe avec le moins d\'objets gagne !"],variante:"Interdire de traverser la ligne centrale pour rendre le lancer obligatoire.",benefice:"Développe la coordination du lancer, la stratégie d\'équipe et l\'endurance.",securite:"Utiliser uniquement des objets mous, délimiter les zones."},
  {id:"GJ010",titre:"La fée et les petits lutins",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"course, réaction, imagination",materiel:"aucun",nbJ:"5-12",consigne:"La fée ensorcelle les lutins ! Mais le magicien peut les sauver.",etapes:["Un joueur est la fée, un autre est le magicien","La fée touche les lutins qui s\'arrêtent figés sur place","Le magicien touche les lutins figés pour les libérer","La fée essaie d\'ensorcelere tout le monde","Le magicien essaie d\'empêcher ça","Après 3 minutes, on change les rôles"],variante:"Donner une baguette (bâton souple) à la fée pour rendre le jeu plus visuel et théâtral.",benefice:"Développe la course, l\'attention et l\'imagination à travers le jeu symbolique.",securite:"Terrain délimité, baguette souple uniquement."},
  {id:"GJ011",titre:"Les écureuils en cage",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, réaction, orientation",materiel:"cerceaux ou zones marquées",nbJ:"6-15",consigne:"Chaque écureuil cherche un arbre creux… mais il faut être le plus rapide !",etapes:["Par groupes de 3 : 2 joueurs forment un arbre (ils se tiennent les mains en arc)","1 joueur est l\'écureuil à l\'intérieur de l\'arbre","Un écureuil est sans arbre — c\'est lui qui cherche","L\'adulte crie Changement ! — tous les écureuils doivent changer d\'arbre en courant","L\'écureuil sans arbre essaie d\'en trouver un","Celui qui se retrouve sans arbre continue à chercher"],variante:"L\'adulte crie aussi Orage ! — à ce signal, les arbres se défont et reforment de nouvelles paires.",benefice:"Développe la course, la réactivité et la coordination en groupe.",securite:"Terrain plat, délimiter la zone de jeu."},
  {id:"GJ012",titre:"Le jeu du béret péi",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, réaction, stratégie d\'équipe",materiel:"1 objet (chapeau, foulard, bâton)",nbJ:"6-20",consigne:"Deux équipes, un objet au centre. Votre numéro est appelé — courez l\'attraper !",etapes:["Formez 2 équipes en ligne face à face, à 5 mètres de l\'objet au centre","Chaque joueur reçoit un numéro (même numéro dans les 2 équipes)","L\'adulte appelle un numéro — les 2 joueurs de ce numéro sprintent vers l\'objet","Celui qui l\'attrape doit revenir dans son camp sans se faire toucher","S\'il est touché avant d\'arriver, l\'équipe adverse marque le point","L\'équipe avec le plus de points gagne"],variante:"Appeler 2 numéros à la fois pour 4 joueurs en même temps !",benefice:"Développe la vitesse de réaction, la stratégie et l\'esprit d\'équipe.",securite:"Terrain plat, l\'objet au centre ne doit pas être pointu."},
  {id:"GJ013",titre:"La balle assise",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"lancer, esquive, coopération",materiel:"1 balle mousse",nbJ:"6-15",consigne:"Touchez les autres avec la balle douce… mais attention au retour de flamme !",etapes:["Un joueur est le lanceur avec la balle mousse","Il essaie de toucher les autres joueurs avec la balle","Le joueur touché s\'assoit sur place (il est éliminé)","Mais si le lanceur est touché par une balle qu\'il a lancée et qui rebondit... il est éliminé lui aussi !","Le dernier debout devient le nouveau lanceur"],variante:"Les joueurs assis peuvent être sauvés si la balle passe à portée de leur main et qu\'ils l\'attrapent.",benefice:"Développe la précision du lancer, l\'esquive et la vigilance.",securite:"Utiliser uniquement une balle mousse très douce, pas de lancer au visage."},
  {id:"GJ014",titre:"Les poules, renards et vipères",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, stratégie, mémoire des règles",materiel:"3 foulards de couleurs différentes",nbJ:"9-18",consigne:"Qui attrape qui ? Poule bat vipère, vipère bat renard, renard bat poule… à vous de trouver !",etapes:["Divisez en 3 équipes : Poules, Renards, Vipères (foulards de couleurs)","La règle : Poule attrape Vipère, Vipère attrape Renard, Renard attrape Poule","Au signal, tout le monde court et attrape ses proies… en fuyant ses prédateurs !","Quand on est attrapé, on rejoint l\'équipe qui nous a attrapé","L\'équipe la plus grande au bout de 3 minutes a gagné"],variante:"Créer des zones de camp intouchable pour souffler 5 secondes.",benefice:"Développe la course, la stratégie et la mémorisation des règles de jeu.",securite:"Terrain délimité, foulards pour éviter les plaquages."},
  {id:"GJ015",titre:"Le soleil et la pluie",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"réaction, contrôle moteur, écoute",materiel:"aucun",nbJ:"4-15",consigne:"Soleil ou pluie — chaque signal déclenche une action différente ! Réagissez vite !",etapes:["Tous les joueurs se dispersent dans l\'espace","L\'adulte annonce des situations météo au hasard","Soleil ! = courir librement en souriant","Pluie ! = s\'accroupir et se protéger la tête","Orage ! = sauter sur place en criant","Cyclone péi ! = tourner en rond","Arc-en-ciel ! = former un cercle avec les autres"],variante:"Accélérer les enchaînements de signaux pour créer des erreurs rigolotes.",benefice:"Développe l\'écoute, la réactivité et le contrôle moteur de façon ludique.",securite:"Terrain plat, délimiter l\'espace."},
  {id:"TP065",titre:"Course aux ombres",lieu:"Extérieur",duree:"20-30 min",intensite:"Modérée",objectif:"course, repérage",materiel:"aucun",nbJ:"1-4",consigne:"Ne restez jamais au soleil ! Courez d\'ombre en ombre.",etapes:["Repérez les zones d\'ombre autour de vous","Courez de l\'une à l\'autre sans rester au soleil","Comptez combien de zones d\'ombre vous trouvez","Qui trouve le chemin le plus court entre 2 ombres ?"],variante:"Compter les zones d\'ombre trouvées pendant toute la balade.",benefice:"Développe le repérage spatial et la course en conditions réelles.",securite:"Surveiller les surfaces."},
  {id:"GJB01",titre:"La balle au chasseur",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"lancer, esquive, réaction",materiel:"1 balle mousse",nbJ:"5-15",consigne:"Le chasseur lance la balle mousse sur les lapins. Un lapin qui attrape la balle prend la place du chasseur !",etapes:["Un joueur est le chasseur avec une balle mousse","Les autres joueurs sont des lapins qui se déplacent librement","Le chasseur lance la balle pour toucher les lapins","Lapin touché = s\'assoit sur place","Si un lapin attrape la balle sans la faire tomber, il devient chasseur","Les lapins assis peuvent être libérés s\'ils touchent la balle qui passe près d\'eux"],variante:"Ajouter 2 chasseurs pour pimenter. Interdire de viser la tête.",benefice:"Développe la précision du lancer, l\'esquive et la réactivité.",securite:"Utiliser uniquement une balle mousse très douce, jamais de tir au visage."},
  {id:"GJB02",titre:"Ballon-tunnel",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"coordination, coopération, lancer précis",materiel:"1 ballon",nbJ:"6-15",consigne:"Faites passer la balle entre les jambes de votre camarade — en cercle, tout le monde défend sa porte !",etapes:["Les joueurs forment un cercle debout, jambes écartées","Les pieds de chaque joueur touchent ceux de ses voisins","Le but : faire passer la balle entre les jambes d\'un camarade","Chaque joueur défend sa porte avec ses mains","Celui à qui la balle passe entre les jambes se retourne et joue dans l\'autre sens !"],variante:"Faire deux cercles plus petits en parallèle pour plus d\'action.",benefice:"Développe la coordination, la vigilance et l\'esprit d\'équipe.",securite:"Cercle bien formé, sol plat."},
  {id:"GJB03",titre:"Vider sa maison",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"lancer, stratégie d\'équipe, endurance",materiel:"6-10 balles molles, 2 zones",nbJ:"6-20",consigne:"Lancez tous les ballons dans le camp adverse ! L\'équipe avec le moins de ballons à la fin gagne.",etapes:["Divisez le terrain en 2 camps avec une ligne centrale","Placez 5 balles molles dans chaque camp","Au signal, chaque équipe lance ses balles dans le camp adverse","On ne peut lancer qu\'une balle à la fois","Au signal de fin (2-3 min), on compte les balles dans chaque camp","L\'équipe avec le moins de balles a gagné !"],variante:"Interdire de traverser la ligne centrale. Ajouter des balles à mi-parcours.",benefice:"Développe le lancer, la stratégie collective et l\'endurance.",securite:"Utiliser uniquement des objets mous, délimiter les zones clairement."},
  {id:"GJB04",titre:"Balle aux prisonniers douceur",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"lancer, esquive, coopération d\'équipe",materiel:"1-2 balles mousse",nbJ:"8-20",consigne:"Touchez les adversaires avec la balle mousse. Touché = prisonnier ! Mais vos coéquipiers peuvent vous libérer.",etapes:["Divisez en 2 équipes, chacune dans son camp","Délimitez une zone prison derrière chaque camp","Les joueurs lancent la balle mousse pour toucher les adversaires","Touché = prisonnier dans la zone prison adverse","Un prisonnier est libéré si un coéquipier lui passe la balle","Version 3-6 ans : libération automatique après 30 secondes !"],variante:"2 balles en jeu pour plus d\'intensité. Jamais de tir au visage.",benefice:"Développe le lancer ciblé, l\'esquive et la coopération d\'équipe.",securite:"Balle mousse obligatoire, aucun tir au visage, terrain délimité."},
  {id:"GJB05",titre:"Le château fort",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"lancer, viser, défense collective",materiel:"ballons, quilles ou bouteilles",nbJ:"6-15",consigne:"Des assiégeants lancent leur ballon pour renverser les tours. Des défenseurs protègent le château !",etapes:["Placez 8-10 quilles (ou bouteilles) au centre d\'un cercle de 4 mètres","Tracez une ligne à 2-3 mètres : zone de tir","2 défenseurs gardent les tours SANS toucher le ballon (pieds uniquement !)","Les assiégeants lancent leur ballon depuis la ligne","But : renverser toutes les tours","Les défenseurs changent toutes les 2 minutes"],variante:"Augmenter la distance de tir. Ajouter un troisième défenseur pour les petits groupes.",benefice:"Développe la précision du lancer et la coopération défensive.",securite:"Utiliser des ballons légers, les défenseurs jouent des pieds uniquement."},
  {id:"GJB06",titre:"Le ballon brûlant",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"passes, rapidité, concentration",materiel:"1 ballon",nbJ:"5-15",consigne:"Passez le ballon le plus vite possible ! Celui qui le tient quand l\'adulte siffle fait un gage rigolo.",etapes:["Les joueurs forment un cercle","On se passe le ballon le plus vite possible","L\'adulte siffle au moment qu\'il veut","Celui qui tient le ballon au signal fait un gage rigolo","Gage péi : sauter 3 fois, imiter un lézard, crier comme un paille-en-queue…","Personne n\'est éliminé définitivement — on recommence !"],variante:"Deux ballons simultanément pour doubler la difficulté et le rire !",benefice:"Développe la rapidité des passes et la concentration dans l\'ambiance joyeuse.",securite:"Dégager l\'espace, pas de poussée."},
  {id:"GJS07",titre:"Quelle heure est-il Monsieur le Loup ?",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"course, réaction, anticipation",materiel:"aucun",nbJ:"4-15",consigne:"Avancez doucement vers le loup en demandant l\'heure… mais méfiez-vous de minuit !",etapes:["Un joueur est le Loup : il se place dos aux autres, à 10 mètres","Les autres sont les moutons, sur la ligne de départ","Ils avancent en demandant : Quelle heure est-il Monsieur le Loup ?","Le Loup répond une heure et les moutons avancent d\'autant de pas","Quand le Loup répond Minuit ! il se retourne et chasse les moutons","Les moutons doivent fuir jusqu\'à la bergerie (ligne de départ) !","Mouton attrapé = devient le nouveau Loup"],variante:"Version péi : Le loup répond en créole pour les heures !",benefice:"Développe la course, la réactivité et l\'anticipation.",securite:"Terrain plat, délimiter la zone de jeu."},
  {id:"GJS08",titre:"Le petit Poucet",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, coopération, orientation",materiel:"petits objets (cailloux, peluches)",nbJ:"5-15",consigne:"Les frères du Petit Poucet récupèrent les cailloux avant que l\'ogre ne finisse de s\'habiller !",etapes:["Dispersez 15 petits objets (les cailloux) sur le terrain","Un panier = la maison du Petit Poucet","Un adulte est l\'Ogre : il fait semblant de s\'habiller très lentement","Les enfants en file indienne partent un par un récupérer UN caillou","Si l\'Ogre crie Grr ! il part chasser — les enfants touchés reposent leur caillou","L\'équipe gagne si tous les cailloux sont dans la maison avant que l\'Ogre ait fini !"],variante:"Augmenter la vitesse de l\'Ogre au fil du jeu.",benefice:"Développe la course, la coopération et la gestion du risque.",securite:"Terrain plat, délimiter la zone de jeu."},
  {id:"GJS09",titre:"Les gazelles et les crocodiles",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, esquive, vitesse",materiel:"foulards",nbJ:"6-20",consigne:"Les gazelles traversent la rivière sans se faire voler leur foulard par les crocodiles !",etapes:["Tracez 2 lignes parallèles (la rivière) espacées de 4-5 mètres","2-3 joueurs sont les Crocodiles : ils restent DANS la rivière","Les autres sont les Gazelles : elles ont un foulard à leur ceinture","Au signal, les gazelles doivent traverser la rivière","Les crocodiles essaient d\'arracher le foulard des gazelles","Gazelle sans foulard = devient crocodile","Gagne la gazelle qui traverse le plus souvent !"],variante:"Augmenter le nombre de crocodiles au fil du jeu.",benefice:"Développe la vitesse, l\'esquive et la réactivité.",securite:"Les crocodiles ne peuvent pas sortir de la rivière, terrain plat."},
  {id:"GJS10",titre:"Le ballon en l\'air baudruche",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"coopération, coordination, concentration",materiel:"1 ballon de baudruche",nbJ:"3-12",consigne:"Le ballon ne doit pas toucher le sol ! Frappez-le à tour de rôle avec n\'importe quelle partie du corps.",etapes:["Gonflez un ballon de baudruche","Lancez-le en l\'air au centre du groupe","Chacun frappe à son tour pour le maintenir en l\'air","On peut frapper avec les mains, les pieds, la tête, les coudes…","Comptez ensemble combien de fois vous y touchez","Battez votre record à chaque partie !"],variante:"Jouer en équipes face à face ou avec 2 ballons pour les grands groupes.",benefice:"Développe la coopération et la coordination de groupe.",securite:"Dégager l\'espace, ballon très léger pour les tout-petits."},
  {id:"GJC11",titre:"La tente géante",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Calme",objectif:"coopération, synchronisation, lien de groupe",materiel:"grand drap ou parachute",nbJ:"6-20",consigne:"Ensemble vous allez faire gonfler un drap géant et construire une tente où tout le monde rentre !",etapes:["Tous les joueurs tiennent le bord du drap face à face","Ensemble, levez le drap à bout de bras 3 fois (pour lui donner de l\'air)","La 3e fois, avancez rapidement de 2-3 pas vers le centre","Rassemblez le bord du drap sous vos fesses et asseyez-vous dessus","Vous voilà tous à l\'intérieur d\'une grande tente !","Variante requin : un joueur glisse dessous pour toucher les autres"],variante:"Le requin : sous la tente, un joueur promène sa main comme une nageoire pour toucher les pieds !",benefice:"Développe la synchronisation collective et la coopération.",securite:"Avancer ensemble, éviter les trébuchements."},
  {id:"GJC12",titre:"Les vagues de la mer",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"coopération, écoute, rythme de groupe",materiel:"grand drap",nbJ:"6-20",consigne:"L\'adulte raconte une histoire météo, et le drap devient la mer ! Créez ensemble petites vagues, tempête et raz-de-marée !",etapes:["Tous les joueurs tiennent le bord du drap à deux mains","L\'adulte annonce la météo en racontant une histoire","Mer calme = agiter doucement","Tempête = agiter fort","Raz-de-marée péi ! = lever très haut et abaisser vite","Échange de couleurs : une couleur est annoncée, les joueurs concernés lâchent et courent changer de place pendant que la mer monte !"],variante:"Placer une balle légère sur le drap et la faire rouler sans qu\'elle tombe.",benefice:"Développe l\'écoute, la synchronisation et la coopération ludique.",securite:"Pas de courir sous le drap levé, s\'assurer que les échanges se font sans collision."},
  {id:"GJP13",titre:"Minuit dans la bergerie",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"course, réaction, stratégie",materiel:"aucun",nbJ:"5-15",consigne:"Les moutons rentrent à la bergerie avant minuit… mais le loup est toujours là !",etapes:["Délimitez une bergerie (zone protégée) et une prairie","Un joueur est le Loup : il se promène dans la prairie","Les moutons demandent : Loup es-tu là ? Que fais-tu ?","Le loup répond en décrivant ce qu\'il fait (il s\'habille, déjeune, se prépare…)","Quand il répond : Je viens vous manger ! il court attraper les moutons","Les moutons doivent fuir jusqu\'à la bergerie !","Mouton attrapé = devient loup"],variante:"Jouer en duo de moutons : ils se tiennent par la main et doivent traverser ensemble.",benefice:"Développe la course, l\'écoute et la réactivité.",securite:"Terrain plat, délimiter clairement la bergerie."},
  {id:"GJP14",titre:"Le chasseur de ballons (épervier ballon)",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"dribble ou transport, vitesse, esquive",materiel:"1 ballon par joueur",nbJ:"6-15",consigne:"Traversez le terrain avec votre ballon sans que l\'épervier ne le fasse sortir !",etapes:["Chaque joueur se place derrière la ligne de fond avec son ballon","Un épervier est au centre du terrain","Au signal, tous traversent avec leur ballon (en le tenant ou en le dribblant)","L\'épervier essaie d\'envoyer les ballons hors du terrain","Joueur dont le ballon est sorti = s\'assoit et forme un obstacle","Les joueurs restants continuent de traverser"],variante:"Les joueurs assis peuvent toucher les ballons qui passent près d\'eux.",benefice:"Développe la maîtrise du ballon, la vitesse et l\'esquive.",securite:"Terrain délimité, pas de poussée."},
  {id:"GJP15",titre:"Le grand jeu du nombre",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Modérée",objectif:"course, réaction, calcul mental doux",materiel:"aucun",nbJ:"6-20",consigne:"L\'adulte annonce un nombre — formez un groupe de ce nombre, le plus vite possible !",etapes:["Les joueurs se déplacent librement dans l\'espace","L\'adulte crie un nombre : 3 !","Les joueurs doivent former des groupes exactement de 3 personnes","Les joueurs qui n\'ont pas de groupe ou sont en trop font un gage rigolo","On reprend immédiatement avec un nouveau nombre"],variante:"Annoncer la couleur de vêtement ou une autre caractéristique pour se regrouper.",benefice:"Développe la réactivité, le calcul rapide et la socialisation.",securite:"Dégager l\'espace, pas de bousculade pour former les groupes."},
  {id:"GJP16",titre:"Chat-souris délivreur",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, coopération, solidarité",materiel:"aucun",nbJ:"5-15",consigne:"Le chat attrape les souris — mais une souris libre peut toujours en délivrer une autre !",etapes:["Un joueur est le chat","Quand le chat touche une souris, elle s\'immobilise jambes écartées","Une souris libre peut passer entre les jambes d\'une souris figée pour la délivrer","Le chat essaie de figer tout le monde","S\'il y réussit, il peut se choisir un assistant","Le dernier joueur non figé devient le nouveau chat"],variante:"Le sauveur doit dire une formule magique : Alakazam péi ! en libérant quelqu\'un.",benefice:"Développe la coopération, la course et le sens du collectif.",securite:"Terrain délimité, surveiller les chutes."},
  {id:"GJP17",titre:"Les facteurs et les loups",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, coopération, orientation",materiel:"petits objets à transporter",nbJ:"6-15",consigne:"Les facteurs doivent livrer tous leurs colis à la maison… mais les loups les guettent !",etapes:["Dispersez des objets (colis) dans le terrain","La maison (panier) est à un bout du terrain","2 joueurs sont des loups qui patrouillent","Les facteurs doivent récupérer les colis UN par UN et les ramener","Si un loup touche un facteur, celui-ci pose son colis et retourne au départ","L\'équipe gagne si tous les colis sont livrés avant la fin du temps"],variante:"Augmenter le nombre de loups. Ajouter des refuges (zones intouchables 5 secondes).",benefice:"Développe la course, la coopération et la stratégie de groupe.",securite:"Terrain délimité, loups ne peuvent pas rester sur place."},
  {id:"GJP18",titre:"Le jeu des déménageurs",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, coopération, stratégie",materiel:"petits objets colorés, 2 zones",nbJ:"6-20",consigne:"Récupérez les objets de la couleur de votre équipe et rapportez-les dans votre camp !",etapes:["Dispersez des objets de 2 couleurs différentes au centre du terrain","Chaque équipe a un camp et une couleur","Au signal, les joueurs courent récupérer les objets de leur couleur","On ne transporte qu\'un objet à la fois","L\'équipe qui a récupéré tous ses objets en premier gagne"],variante:"Ajouter un épervier au centre qui peut toucher les joueurs et les faire reposer leurs objets.",benefice:"Développe la course, la coopération et la compréhension des règles.",securite:"Terrain délimité, objets mous uniquement."},
  {id:"GJP19",titre:"La spirale de l\'escargot",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Calme",objectif:"équilibre, coordination, patience",materiel:"craie ou corde au sol",nbJ:"4-12",consigne:"Suivez le tracé de la spirale jusqu\'au centre, puis ressortez sans se tromper !",etapes:["Dessinez une grande spirale au sol à la craie (ou posez une corde en spirale)","Les joueurs entrent dans la spirale en file indienne","Ils marchent jusqu\'au centre sans sortir du tracé","Puis ils ressortent en sens inverse","Choisissez un mode de déplacement : pas de géant, à cloche-pied, comme un animal…"],variante:"Faire la spirale à deux en se tenant la main. Ajouter des petits obstacles sur le tracé.",benefice:"Développe la patience, la coordination et l\'équilibre.",securite:"Pas de course dans la spirale, sol plat."},
  {id:"GJP20",titre:"Le jeu du roi des cochons",lieu:"Grand Jeu",duree:"15-20 min",intensite:"Dynamique",objectif:"course, réaction, observation",materiel:"aucun",nbJ:"6-15",consigne:"Le Roi des Cochons ordonne des actions rigolotes. Mais si ce n\'est pas LUI qui ordonne, personne ne bouge !",etapes:["Un joueur est le Roi des Cochons","Il donne des ordres précédés de : Le Roi des Cochons ordonne de…","Les joueurs obéissent SEULEMENT si l\'ordre commence par cette formule","Si le joueur dit juste courir en rond… personne ne bouge","Celui qui se trompe devient le nouveau Roi des Cochons","Les ordres doivent être des actions physiques : sauter, courir, se baisser…"],variante:"Accélérer le rythme des ordres pour créer des erreurs rigolotes !",benefice:"Développe l\'écoute, la réactivité et le contrôle inhibitoire.",securite:"Terrain délimité, dégager l\'espace."},
  {id:"GJP21",titre:"Les musiciens ambulants",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"rythme, coopération, écoute",materiel:"musique (téléphone)",nbJ:"4-15",consigne:"Marchez en rythme, formez des groupes au signal, bougez selon la musique !",etapes:["Mettez de la musique (musique créole de préférence !)","Les joueurs marchent librement au rythme de la musique","L\'adulte baisse le volume soudainement","Les joueurs doivent imiter le dernier geste du chef (l\'adulte)","Remettez la musique, les joueurs repartent librement","Répétez avec des gestes différents à chaque arrêt"],variante:"À chaque arrêt, l\'adulte désigne un enfant comme nouveau chef.",benefice:"Développe le sens du rythme, l\'écoute et la coordination.",securite:"Dégager l\'espace."},
  {id:"GJP22",titre:"Les îles musicales",lieu:"Grand Jeu",duree:"10-15 min",intensite:"Modérée",objectif:"course, réaction, équilibre",materiel:"cerceaux ou zones tracées au sol, musique",nbJ:"4-15",consigne:"Dansez librement… mais quand la musique s\'arrête, trouvez une île vite !",etapes:["Placez des cerceaux au sol (1 de moins que le nombre de joueurs)","Mettez de la musique : tout le monde danse librement","Quand la musique s\'arrête, chacun doit se mettre dans un cerceau","Le joueur sans cerceau fait un gage rigolo","Retirez un cerceau à chaque tour"],variante:"Plusieurs joueurs peuvent partager un cerceau (coopération !) si vous retirez moins de cerceaux.",benefice:"Développe la réactivité, la coordination et le plaisir du mouvement.",securite:"Cerceaux bien posés à plat, terrain dégagé."},
  {id:"JB01",titre:"Boîte à trésors nature",lieu:"Extérieur",duree:"20-30 min",intensite:"Calme",objectif:"observation, motricité fine, curiosité",materiel:"petit sac ou boîte à œufs",nbJ:"1-4",consigne:"Pendant la balade, ramassez des petits trésors naturels. À la fin, chacun présente sa collection !",etapes:["Donnez un petit sac ou une boîte à chaque enfant","Pendant la balade, l\'enfant ramasse des trésors naturels : jolie feuille, caillou, plume, fleur tombée","Il choisit librement ce qu\'il trouve beau ou intéressant","À la fin de la balade, chacun montre ses trésors préférés","Quel est ton trésor numéro 1 ?"],variante:"Version couleurs : ramasser un trésor de chaque couleur. Version bord de mer : coquillages et galets. Version 1 trésor par arrêt.",benefice:"Développe l\'observation fine, la curiosité et le vocabulaire de la nature.",securite:"Vérifier que l\'enfant ne ramasse rien de dangereux (verre, plante irritante, insecte)."},
  {id:"JB02",titre:"Détective nature",lieu:"Extérieur",duree:"15-20 min",intensite:"Calme",objectif:"observation, comparaison, concentration",materiel:"aucun ou petite fiche imagée",nbJ:"1-4",consigne:"Donnez une mini mission d\'observation : trouver 3 feuilles différentes, 2 bâtons, 1 chose qui pique !",etapes:["Choisissez une mission adaptée au lieu : 3 feuilles de forme différente, 2 bâtons de taille différente, quelque chose de doux ET de rugueux","L\'enfant part enquêter dans l\'espace proche","Il revient présenter ses trouvailles en expliquant pourquoi elles sont différentes","Validez avec enthousiasme et posez une question : Comment tu sais que c\'est différent ?"],variante:"Version plage : types de galets différents. Version parc : 3 arbres différents. Version saison : trouver des signes du printemps.",benefice:"Développe l\'attention visuelle, la comparaison et le vocabulaire scientifique.",securite:"Adapter les missions à l\'environnement disponible."},
  {id:"JB03",titre:"Le chef de file",lieu:"Extérieur",duree:"20-30 min",intensite:"Modérée",objectif:"initiative, confiance en soi, leadership doux",materiel:"aucun",nbJ:"2-5",consigne:"Un enfant devient le guide de la balade ! Il choisit le chemin et donne de petites missions aux autres.",etapes:["Désignez un Chef de file (tournez à chaque balade)","Il marche en tête et choisit le chemin","Il peut aussi donner des missions : Sautez par-dessus cette ligne ! Touchez cet arbre !","Changez de chef toutes les 5 minutes","Chaque enfant doit avoir son tour de chef"],variante:"Version capitaine de bateau : naviguer vers un horizon imaginaire. Version explorateur : nommer les lieux découverts.",benefice:"Développe l\'initiative, la confiance en soi et le sens des responsabilités.",securite:"Éviter qu\'un seul enfant décide toujours. Rester dans la zone sécurisée."},
  {id:"JB04",titre:"Land art péi",lieu:"Extérieur",duree:"15-25 min",intensite:"Calme",objectif:"créativité, patience, motricité fine",materiel:"éléments trouvés sur place uniquement",nbJ:"1-4",consigne:"Créez une œuvre d\'art avec ce que vous trouvez au sol : feuilles, bâtons, cailloux, fleurs tombées. Une vraie galerie en plein air !",etapes:["Ramassez des éléments au sol : feuilles, cailloux, brindilles, fleurs tombées (jamais cueillies !)","Trouvez un espace plat pour créer","Composez une forme : soleil, animal, visage, maison, spirale…","Prenez une photo souvenir de l\'œuvre","Laissez l\'œuvre sur place : elle est à la nature !"],variante:"Version mandala : des cercles concentriques avec les éléments triés par couleur. Version prénom : écrire son prénom en bâtons et cailloux.",benefice:"Développe la créativité, la patience et la connexion à la nature.",securite:"Utiliser uniquement ce qui est déjà tombé au sol. Pas de cueillette."},
  {id:"JB05",titre:"Je vois, je vois…",lieu:"Extérieur",duree:"15-20 min",intensite:"Calme",objectif:"observation, langage, vocabulaire descriptif",materiel:"aucun",nbJ:"2-5",consigne:"Je vois quelque chose de vert et qui bouge… Devinez ! Le jeu classique de la devinette en pleine nature.",etapes:["L\'adulte commence : Je vois quelque chose de…","Il donne un ou deux indices : couleur, taille, matière, mouvement","L\'enfant regarde autour de lui et propose des réponses","Quand il a trouvé, c\'est à lui de jouer","Encouragez des descriptions précises : grand, petit, rugueux, brillant…"],variante:"Version sonore : J\'entends quelque chose… Version tactile : Je touche quelque chose de… Version forme : Je vois quelque chose de rond…",benefice:"Développe le vocabulaire descriptif, l\'observation et le langage.",securite:"Laisser l\'enfant proposer aussi ses propres devinettes."},
  {id:"JB06",titre:"Mission équilibre",lieu:"Extérieur",duree:"15-20 min",intensite:"Modérée",objectif:"équilibre dynamique, concentration, coordination",materiel:"bordures, lignes au sol, petites pierres naturelles",nbJ:"1-4",consigne:"Marchez comme des funambules sur toutes les lignes et bordures que vous trouvez !",etapes:["Repérez les lignes naturelles : bordure de trottoir, ligne de graviers, bord d\'un muret bas","L\'enfant marche sur la ligne sans tomber les bras écartés","Progressez : d\'abord lentement, puis en transportant un objet","Version avancée : marcher à reculons, ou les yeux mi-fermés avec un adulte à côté"],variante:"Transporter une feuille à plat dans les mains sans la faire tomber. Marcher très lentement comme au ralenti.",benefice:"Renforce l\'équilibre dynamique et la concentration.",securite:"Choisir uniquement des surfaces basses et sécurisées. Toujours sécuriser l\'enfant."},
  {id:"JB07",titre:"Le bâton magique",lieu:"Extérieur",duree:"10-20 min",intensite:"Calme",objectif:"imagination, motricité, expression",materiel:"un bâton trouvé par terre",nbJ:"1-4",consigne:"Trouvez LE meilleur bâton… et inventez ce qu\'il devient ! Baguette magique, canne de sorcier, micro de star ?",etapes:["Chaque enfant cherche son bâton parfait (ni trop petit, ni trop grand)","Il lui donne un nom et une superpouvoir","À quoi sert ton bâton magique ? Montre-moi !","Baguette = tracer des formes au sol","Micro = chanter","Canne d\'explorateur = pointer les découvertes","Épée de chevalier = combattre les monstres imaginaires !"],variante:"Version sorcier : inventer une formule magique. Version roi / reine : le bâton est un sceptre royal.",benefice:"Stimule l\'imagination, l\'expression et la motricité fine.",securite:"Jamais de bâton agité près des autres enfants ou du visage."},
  {id:"JB08",titre:"Le roi des sauts",lieu:"Extérieur",duree:"15-20 min",intensite:"Dynamique",objectif:"saut, coordination, contrôle du corps",materiel:"espace dégagé",nbJ:"1-6",consigne:"Qui est le meilleur sauteur ? À chaque annonce, un nouveau type de saut différent !",etapes:["L\'adulte annonce un type de saut","Saut loin = sauter le plus loin possible depuis une ligne","Saut haut = toucher quelque chose en hauteur","Saut silencieux = atterrir sans faire de bruit","Saut grenouille = accroupi, puis saut","Saut kangourou = 5 sauts enchaînés","Saut en étoile = les bras et jambes écartés"],variante:"Pieds joints uniquement pour les plus petits. Version relais : saut en équipe. Version devinette : l\'adulte mime un animal qui saute.",benefice:"Renforce les jambes, améliore la coordination et le contrôle des atterrissages.",securite:"Sol stable et non glissant. Jamais de saut en hauteur, uniquement en longueur ou sur place."},
  {id:"JB09",titre:"Le facteur nature",lieu:"Extérieur",duree:"15-20 min",intensite:"Modérée",objectif:"déplacement avec mission, orientation, endurance douce",materiel:"feuille, caillou ou petit objet naturel",nbJ:"1-4",consigne:"Mission spéciale : livrer ce colis jusqu\'au grand arbre et revenir ! Le facteur péi est en route !",etapes:["L\'adulte donne un petit objet naturel (feuille, caillou)","Il désigne un endroit précis et visible : le grand arbre, le banc rouge, la fontaine","L\'enfant porte l\'objet jusqu\'à cet endroit, le pose, et revient","À chaque livraison réussie, une nouvelle mission","Le mode de déplacement change à chaque fois : courir, sautiller, marcher à reculons…"],variante:"Version duo : deux enfants portent ensemble un objet fragile. Version message secret : la feuille est un message plié.",benefice:"Développe l\'orientation dans l\'espace et l\'endurance douce avec une motivation par la mission.",securite:"Bien montrer l\'endroit de livraison avant le départ. Rester dans la zone visible."},
  {id:"JB10",titre:"Chasse aux sons",lieu:"Extérieur",duree:"10-15 min",intensite:"Calme",objectif:"écoute, concentration, retour au calme",materiel:"aucun",nbJ:"1-6",consigne:"Stop ! On ferme les yeux et on écoute… Combien de sons différents entendez-vous ?",etapes:["Demandez à tout le monde de s\'arrêter et de se taire","Fermez les yeux (ou baissez la tête)","Écoutez pendant 30 secondes à 1 minute","Rouvrez les yeux et listez tout ce que vous avez entendu","Oiseaux, vent, feuilles, voitures, insectes, pas…","Qui a entendu le plus de sons différents ?"],variante:"Compter les sons avec les doigts. Version avancée : reconnaître sans regarder. Version dessin : dessiner un son entendu.",benefice:"Développe l\'écoute active et la concentration. Excellent pour calmer le groupe.",securite:"Très utile pour les moments de retour au calme en fin de balade."},
  {id:"JB11",titre:"Mime nature",lieu:"Extérieur",duree:"10-15 min",intensite:"Calme",objectif:"expression corporelle, imagination, vocabulaire",materiel:"aucun",nbJ:"2-6",consigne:"Montre-moi un arbre dans le vent ! Un escargot sous la pluie ! Un papillon qui s\'envole !",etapes:["L\'adulte annonce un élément naturel à mimer","L\'enfant l\'interprète avec son corps sans parler","Arbre dans le vent = se balancer les bras en l\'air","Escargot = ramper très lentement","Papillon = courir bras écartés en tournant","Caillou = s\'immobiliser complètement","Vague = ondulations du corps","Les autres devinent si c\'est une devinette"],variante:"Mime à deux : deux enfants miment ensemble (arbre + oiseau). Version devinette : les autres doivent trouver.",benefice:"Développe l\'expression corporelle, l\'imagination et la conscience du corps.",securite:"Valoriser toutes les interprétations — il n\'y a pas de mauvaise réponse."},
  {id:"JB12",titre:"Cherche et touche",lieu:"Extérieur",duree:"15-20 min",intensite:"Calme",objectif:"sensations tactiles, vocabulaire sensoriel, curiosité",materiel:"aucun",nbJ:"1-4",consigne:"Trouve quelque chose de doux… de rugueux… de froid… On explore la nature avec les mains !",etapes:["L\'adulte annonce une sensation","L\'enfant part chercher dans l\'environnement proche quelque chose qui correspond","Doux = mousse, herbe fine, pétale","Rugueux = écorce, vieux mur","Froid = pierre à l\'ombre, métal","Humide = herbe du matin","Léger = feuille fine, plume","Il revient le montrer et expliquer pourquoi"],variante:"Version yeux fermés avec l\'aide d\'un adulte : trouver la sensation sans regarder. Version classement : trier les trouvailles du plus doux au plus rugueux.",benefice:"Développe la discrimination tactile et le vocabulaire sensoriel.",securite:"Attention aux plantes irritantes et aux surfaces qui peuvent blesser."},
  {id:"JB13",titre:"Retour des explorateurs",lieu:"Extérieur",duree:"10-15 min",intensite:"Calme",objectif:"langage, valorisation, mémoire",materiel:"les objets trouvés pendant la balade",nbJ:"1-6",consigne:"La balade est finie — c\'est l\'heure de partager ! Chacun montre son trésor préféré et raconte son meilleur moment.",etapes:["Formez un petit cercle assis ou debout","Chacun montre l\'objet ou le moment préféré de la balade","L\'adulte pose des questions ouvertes : Pourquoi tu as aimé ça ? Comment ça s\'appelle ?","Valorisez chaque contribution : Super observation ! Tu as vraiment bien regardé !","Terminez sur une note positive : La prochaine fois on ira où ?"],variante:"Version cercle de parole : chacun parle à son tour avec un objet-micro. Version dessin souvenir : dessiner son moment préféré en rentrant.",benefice:"Clôture la balade positivement, développe le langage et la mémoire des événements.",securite:"Moment très important pour ancrer les bons souvenirs et donner envie de recommencer."},
  {id:"JM01",titre:"La boîte sensorielle",lieu:"Maison",duree:"10-15 min",intensite:"Calme",objectif:"motricité fine, sensations tactiles, concentration",materiel:"boîte opaque + objets variés du quotidien",nbJ:"1-4",consigne:"Touchez sans regarder et devinez ce que c\'est ! Une boîte mystère pleine de surprises.",etapes:["Remplissez une boîte avec des objets familiers : clé, éponge, bouchon, tissu, caillou, plume…","L\'enfant glisse la main sans regarder","Il touche un objet et décrit ce qu\'il sent : doux, dur, froid, rugueux…","Il devine de quoi il s\'agit avant de regarder","Validez et discutez : comment tu as deviné ?"],variante:"Version tissus : différentes matières seulement. Version cuisine : légumes et fruits. Version jouets : reconnaître ses propres jouets.",benefice:"Développe la discrimination tactile, le vocabulaire sensoriel et la concentration.",securite:"Vérifier que tous les objets sont sûrs, sans arêtes ni risque d\'ingestion."},
  {id:"JM02",titre:"La tour géante",lieu:"Maison",duree:"10-15 min",intensite:"Calme",objectif:"précision, patience, motricité fine",materiel:"gobelets en plastique, boîtes de conserve vides, kapla ou blocs",nbJ:"1-4",consigne:"Construisez la tour la plus haute possible… sans la faire tomber ! Chaque étage est une victoire.",etapes:["Rassemblez des gobelets en plastique ou des boîtes légères","Posez le premier bloc ou gobelet bien à plat","Ajoutez les éléments un par un, très délicatement","Comptez les étages ensemble","Quand elle tombe, riez et recommencez plus haut !"],variante:"Version chronométrée : combien d\'étages en 2 minutes ? Version construction à thème : un château, une fusée, un immeuble.",benefice:"Développe la précision des gestes, la patience et la gestion de la frustration.",securite:"Préférer des matériaux légers. La frustration si ça tombe est normale — valoriser l\'effort."},
  {id:"JM03",titre:"Mission rangement express",lieu:"Maison",duree:"10-15 min",intensite:"Modérée",objectif:"tri, classification, autonomie, motricité",materiel:"jouets éparpillés, paniers ou zones",nbJ:"1-4",consigne:"Transformez le rangement en mission secrète ! Sauvez les dinosaures, triez les couleurs, battez le chrono !",etapes:["Éparpillez les jouets ou objets au sol","Annoncez la mission : Sauve tous les dinosaures avant que le volcan explose !","Ou : Trie par couleur : rouge ici, bleu là !","L\'enfant range selon la consigne en courant doucement","Validez chaque réussite avec enthousiasme"],variante:"Version chrono : battre son propre record. Version mission secrète : chuchoter la consigne à l\'oreille.",benefice:"Développe l\'autonomie, la classification et la motricité tout en rendant une tâche quotidienne ludique.",securite:"Rester ludique — jamais de pression ni de punition liée au rangement."},
  {id:"JM04",titre:"Le coussin équilibre",lieu:"Maison",duree:"10-15 min",intensite:"Modérée",objectif:"équilibre statique, concentration, contrôle postural",materiel:"coussin épais ou plié en double",nbJ:"1-4",consigne:"Tenez en équilibre sur le coussin ! Surface instable = super entraînement pour les jambes et la concentration.",etapes:["Posez un coussin épais au sol","L\'enfant monte dessus et essaie de tenir debout","Défi 1 : tenir 5 secondes sur deux pieds","Défi 2 : tenir sur un pied comme un flamant rose","Défi 3 : attraper un objet léger tendu par le parent sans tomber","Défi 4 : recevoir et renvoyer une balle mousse en restant sur le coussin"],variante:"Tenir un objet dans les mains pendant l\'équilibre. Version relais : passer sur le coussin sans tomber.",benefice:"Renforce l\'équilibre statique, la proprioception et la concentration posturale.",securite:"Toujours rester proche pour aider. Sol non glissant autour du coussin."},
  {id:"JM05",titre:"La chasse au trésor maison",lieu:"Maison",duree:"15-25 min",intensite:"Modérée",objectif:"orientation spatiale, logique, lecture d\'indices, motivation",materiel:"3-4 petits indices écrits ou dessinés, petit trésor",nbJ:"1-4",consigne:"Des indices mystérieux mènent à un trésor caché quelque part dans la maison… À toi de jouer, petit détective !",etapes:["Préparez 3-4 indices simples : une image ou un mot pointant vers un lieu (le canapé, sous le lit, dans la cuisine…)","Placez un indice à chaque endroit qui mène au suivant","Donnez le premier indice à l\'enfant","Il lit (ou vous lisez) et part chercher","Le trésor final : un autocollant, un galet peint, une petite surprise"],variante:"Version pirate : dessinez une vraie carte. Version détective : photos des endroits au lieu de mots. Version super-héros : mission urgente.",benefice:"Développe l\'orientation dans l\'espace, la logique et la lecture de symboles.",securite:"Indices très simples et clairs. Ne pas cacher dans des endroits dangereux ou difficiles d\'accès."},
  {id:"JM06",titre:"Le tunnel secret",lieu:"Maison",duree:"10-15 min",intensite:"Modérée",objectif:"ramper, motricité globale, imagination",materiel:"drap ou couverture + chaises ou table",nbJ:"1-4",consigne:"Fabriquez une grotte secrète ou un tunnel magique avec un drap ! Ramper dedans, c\'est une aventure à chaque fois.",etapes:["Disposez 2-3 chaises en ligne ou utilisez le dessous d\'une table","Drapez une couverture ou un drap dessus pour créer le tunnel","L\'enfant rampe à l\'intérieur d\'un bout à l\'autre","Variante lampe : donner une petite lampe de poche pour l\'explorer","Variante mission : récupérer un objet caché à l\'intérieur"],variante:"Version explorateur de grottes : raconter une histoire pendant qu\'il rampe. Version obstacle : ajouter des coussins à l\'intérieur.",benefice:"Développe la motricité globale (ramper, fléchir, s\'orienter) et stimule l\'imaginaire.",securite:"Vérifier la stabilité des chaises. Ne pas laisser l\'enfant seul si la structure est fragile."},
  {id:"JM07",titre:"Le jeu du serveur",lieu:"Maison",duree:"10-15 min",intensite:"Modérée",objectif:"coordination, concentration, équilibre dynamique",materiel:"plateau léger ou planche + objets en plastique",nbJ:"1-4",consigne:"Le restaurant est ouvert ! Livrez les commandes sans faire tomber le plateau. Le serveur le plus habile gagne !",etapes:["Posez 2-3 objets légers en plastique sur un plateau ou une planche","L\'enfant porte le plateau à bout de bras sans faire tomber les objets","Parcours simple : traverser la pièce, faire le tour d\'une chaise, revenir","Défi : marcher plus vite à chaque tour","Ajoutez des obstacles à contourner"],variante:"Version rapide : contre la montre. Version verres plastiques avec eau pour les grands : très concentrant !",benefice:"Développe la coordination, la concentration et l\'équilibre dynamique en situation concrète.",securite:"Objets plastiques uniquement. Pas d\'eau pour les 3-4 ans."},
  {id:"JM08",titre:"La mission cuisine",lieu:"Maison",duree:"15-20 min",intensite:"Calme",objectif:"motricité fine, autonomie, concentration",materiel:"fruits, légumes, cuillère, bol, tamis",nbJ:"1-3",consigne:"Tu es mon assistant chef cuisinier ! Une vraie mission avec de vrais outils… et un vrai goûter à la fin !",etapes:["Choisissez une tâche adaptée à l\'âge","3-4 ans : laver des fruits, mélanger, verser d\'un bol à l\'autre","5-6 ans : éplucher une banane, couper des fraises molles avec couteau-jouet, presser un citron","Nommez chaque geste : tu verses, tu mélangera, tu écrase…","Valorisez le résultat même imparfait : tu l\'as fait tout seul !"],variante:"Version salade de fruits : couper et mélanger. Version goûter : préparer les bols. Version recette simple : mélanger une pâte.",benefice:"Développe la motricité fine, l\'autonomie et la fierté de réaliser une tâche réelle.",securite:"Toujours sous surveillance adulte. Couteau adapté à l\'âge uniquement. Valider chaque étape."},
  {id:"JM09",titre:"Le cercle des champions",lieu:"Maison",duree:"5-10 min",intensite:"Calme",objectif:"langage, valorisation, mémoire émotionnelle",materiel:"aucun",nbJ:"1-6",consigne:"La séance est finie — c\'est l\'heure du cercle des champions ! Chacun dit ce qu\'il a réussi ou préféré aujourd\'hui.",etapes:["Asseyez-vous en cercle ou côte à côte sur le canapé","Chacun dit une chose qu\'il a aimée ou réussie pendant la séance","L\'adulte commence pour montrer l\'exemple : Moi j\'ai adoré quand tu as réussi l\'équilibre !","Valorisez chaque contribution : Super observation ! Tu as vraiment bien essayé !","Finissez par un applaudissement collectif ou un geste de victoire inventé ensemble"],variante:"Version dessin souvenir : dessiner son moment préféré juste après. Version applaudissement : inventer un cri de victoire unique à la famille.",benefice:"Ancre les expériences positives, développe le langage et la confiance en soi.",securite:"Moment fondamental pour terminer calmement et donner envie de recommencer."},
  {id:"JJ01",titre:"Parcours moteur naturel",lieu:"Jardin",duree:"15-20 min",intensite:"Modérée",objectif:"équilibre, coordination, confiance",materiel:"pierres, plots, rondins, bordures",nbJ:"1-4",consigne:"Le jardin devient un vrai parcours d\'aventurier ! Chaque obstacle naturel est un défi à relever.",etapes:["Repérez les obstacles naturels du jardin : une bordure à marcher, une racine à enjamber, un arbre à contourner","Créez un enchaînement logique : obstacle 1 → 2 → 3","Expliquez le parcours en mimant chaque étape","Chacun le fait à son rythme","Après 3 tours, changez l\'ordre des obstacles ensemble"],variante:"Version pirate : chaque obstacle a un nom de pirate. Version jungle : chaque zone est un pays différent. Version ninja : se déplacer en silence absolu.",benefice:"Développe l\'équilibre, la coordination et la confiance en ses capacités motrices.",securite:"Vérifier que tous les appuis sont stables et sécurisés avant de commencer."},
  {id:"JJ02",titre:"Chasse aux trésors du jardin",lieu:"Jardin",duree:"15-20 min",intensite:"Calme",objectif:"observation, curiosité, motricité fine",materiel:"petit panier ou boîte",nbJ:"1-4",consigne:"Le jardin est plein de trésors cachés ! Une feuille spéciale, un caillou magique, quelque chose qui sent bon…",etapes:["Donnez un petit panier à chaque enfant","Annoncez les trésors à trouver : une feuille ronde, un caillou spécial, quelque chose qui sent bon, un objet jaune","L\'enfant explore librement le jardin","À la fin, chacun présente ses trouvailles et explique pourquoi c\'est un trésor"],variante:"Version couleurs : un trésor de chaque couleur. Version formes : trouver des formes géométriques dans la nature. Version libre : chacun choisit ses propres critères.",benefice:"Développe l\'observation fine, la curiosité et la motricité fine lors de la collecte.",securite:"Vérifier qu\'il n\'y a pas d\'objets dangereux ou de plantes irritantes dans la zone."},
  {id:"JJ03",titre:"Mission eau péi",lieu:"Jardin",duree:"15-20 min",intensite:"Modérée",objectif:"motricité fine, concentration, coordination",materiel:"arrosoir, gobelets, bassines, cuillères",nbJ:"1-4",consigne:"Transporter l\'eau d\'un récipient à l\'autre avec différents contenants — sans en renverser !",etapes:["Placez une bassine pleine d\'eau à un bout du jardin","Placez un récipient vide à l\'autre bout","L\'enfant transporte l\'eau avec le contenant choisi : gobelet, arrosoir, cuillère","Comptez combien de voyages pour remplir le récipient","Variez les contenants à chaque tour"],variante:"Version relais : plusieurs enfants en chaîne. Version cuillère : transport avec une seule cuillère à soupe. Version arrosoir : utiliser l\'arrosage des plantes comme mission réelle.",benefice:"Développe la motricité fine, la concentration et la persévérance.",securite:"Surveiller le sol glissant si trop d\'eau est renversée. Prévoir des vêtements de rechange !"},
  {id:"JJ04",titre:"Le jardin des animaux",lieu:"Jardin",duree:"15-20 min",intensite:"Modérée",objectif:"schéma corporel, imagination, déplacement varié",materiel:"aucun",nbJ:"1-4",consigne:"Le jardin devient une jungle créole ! Chaque zone est habitée par un animal différent à imiter.",etapes:["Désignez des zones du jardin pour chaque animal","Grenouille = près du robinet","Lapin = dans la pelouse","Escargot = près des fleurs","Oiseau = sous l\'arbre","L\'adulte annonce un animal, l\'enfant se déplace COMME cet animal vers sa zone"],variante:"Version devinette : l\'enfant mime, l\'adulte devine. Version relais animaux : course entre zones en changeant d\'animal à chaque fois.",benefice:"Développe le schéma corporel, l\'imagination et la variété des déplacements.",securite:"Respecter la fatigue et les capacités de chaque enfant."},
  {id:"JJ05",titre:"Land art jardin",lieu:"Jardin",duree:"15-25 min",intensite:"Calme",objectif:"créativité, patience, motricité fine",materiel:"feuilles tombées, fleurs tombées, branches, cailloux",nbJ:"1-4",consigne:"Créez une œuvre d\'art avec ce que le jardin vous offre ! Seulement ce qui est déjà tombé au sol.",etapes:["Ramassez ensemble des éléments tombés : feuilles, cailloux, petites branches, fleurs fanées","Choisissez un espace plat comme toile","Créez une forme ensemble : soleil, animal, maison, spirale","Prenez une photo souvenir","Laissez l\'œuvre sur place — elle est à la nature !"],variante:"Version mandala : cercles concentriques avec éléments triés par couleur. Version prénom : écrire son prénom en bâtons et cailloux. Version cabane miniature.",benefice:"Développe la créativité, la patience et le lien avec la nature.",securite:"Utiliser uniquement ce qui est déjà tombé au sol. Pas de cueillette de plantes vivantes."},
  {id:"JJ06",titre:"Jardin sensoriel",lieu:"Jardin",duree:"15-20 min",intensite:"Calme",objectif:"sensations tactiles, vocabulaire sensoriel, curiosité",materiel:"aucun",nbJ:"1-4",consigne:"Explorez le jardin avec vos mains ! Trouvez quelque chose de doux, de rugueux, de parfumé, d\'humide...",etapes:["L\'adulte annonce une sensation","Doux = herbe fine, pétale","Rugueux = écorce d\'arbre, vieux mur","Parfumé = feuille de menthe, fleur","Humide = herbe du matin, terre après pluie","L\'enfant part chercher et revient montrer sa trouvaille","Discutez : pourquoi c\'est doux ? Qu\'est-ce que ça rappelle ?"],variante:"Version yeux fermés avec aide de l\'adulte : trouver la sensation sans regarder. Version classement : trier les trouvailles du plus doux au plus rugueux.",benefice:"Développe la discrimination tactile, le vocabulaire sensoriel et la curiosité scientifique.",securite:"Attention aux plantes irritantes (ortie, euphorbe). Toujours vérifier avant."},
  {id:"JJ07",titre:"Parcours pieds nus",lieu:"Jardin",duree:"10-15 min",intensite:"Calme",objectif:"proprioception, sensations plantaires, équilibre",materiel:"herbe, tapis extérieur, galets doux, sable",nbJ:"1-4",consigne:"Enlevez les chaussures et marchez sur les différentes surfaces du jardin — chaque texture est une nouvelle sensation !",etapes:["Repérez les différentes surfaces du jardin : herbe, dalle, terre, gravier doux","L\'enfant enlève ses chaussures et ses chaussettes","Marchez lentement d\'une surface à l\'autre","À chaque surface : qu\'est-ce que tu sens ? C\'est agréable ?","Fermez les yeux et devinez la surface sous vos pieds"],variante:"Version yeux fermés avec l\'aide de l\'adulte pour sécuriser. Version parcours guidé : suivre un chemin précis pieds nus.",benefice:"Développe la proprioception, les sensations plantaires et l\'équilibre.",securite:"Vérifier absolument l\'absence d\'objets piquants, de verre ou de surface très chaude avant."},
  {id:"JJ08",titre:"La course brouette",lieu:"Jardin",duree:"10-15 min",intensite:"Dynamique",objectif:"gainage, coopération, force des bras",materiel:"aucun",nbJ:"2-4",consigne:"L\'adulte tient les jambes, l\'enfant avance sur les mains ! La brouette humaine la plus rapide du jardin.",etapes:["L\'enfant se met à plat ventre, mains au sol","L\'adulte tient doucement les chevilles ou les genoux","L\'enfant avance sur les mains, bras tendus","Parcourez une courte distance : 2 à 3 mètres maximum","Reposez-vous et recommencez"],variante:"Très courte distance pour les 3-4 ans. Version aide parent : l\'adulte tient aux hanches plutôt qu\'aux jambes pour plus de sécurité.",benefice:"Renforce le gainage abdominal et les muscles des bras de façon ludique.",securite:"Faire très doucement. Jamais de trop longue distance. Surveiller les mains sur le sol."},
  {id:"JJ09",titre:"Cache-cache nature",lieu:"Jardin",duree:"15-20 min",intensite:"Modérée",objectif:"repérage spatial, orientation, concentration",materiel:"aucun",nbJ:"2-5",consigne:"Le classique du jardin — se cacher derrière les arbres, buissons et coins secrets !",etapes:["Délimitez la zone de jeu clairement","Un joueur ferme les yeux et compte jusqu\'à 10","Les autres se cachent dans la zone","Le chercheur part trouver tout le monde","Le dernier trouvé est le gagnant et compte au prochain tour"],variante:"Version objet caché : cacher un objet au lieu d\'une personne. Version chaud/froid : donner des indices de distance.",benefice:"Développe le repérage spatial, la mémoire des positions et l\'orientation.",securite:"Zone bien délimitée et toujours visible de l\'adulte."},
  {id:"JJ10",titre:"Le jardin musical",lieu:"Jardin",duree:"10-15 min",intensite:"Modérée",objectif:"rythme, écoute, créativité sonore",materiel:"casseroles, cuillères en bois, objets sonores du jardin",nbJ:"1-4",consigne:"Le jardin devient un studio de musique ! Chaque objet est un instrument à découvrir.",etapes:["Rassemblez des objets sonores : casseroles, cuillères en bois, boîtes en métal","Explorez les sons : taper, frotter, souffler dedans","L\'adulte fait un rythme simple, l\'enfant imite","Inventez un morceau ensemble","Enregistrez avec le téléphone si possible !"],variante:"Version fort/faible : varier l\'intensité. Version rapide/lent : varier le tempo. Version orchestre : chacun un instrument différent.",benefice:"Développe le sens du rythme, l\'écoute et la créativité.",securite:"Attention au voisinage — jouer à des horaires raisonnables !"},
  {id:"JJ11",titre:"La mission plantation",lieu:"Jardin",duree:"20-25 min",intensite:"Calme",objectif:"autonomie, motricité fine, patience, responsabilité",materiel:"terre, petit pot ou coin de terre, graines ou plants",nbJ:"1-3",consigne:"Aujourd\'hui tu es jardinier ! Tu vas planter, arroser et t\'occuper de ta propre plante.",etapes:["Préparez ensemble la terre (mélanger, aérer)","L\'enfant fait un petit trou avec son doigt","Il dépose la graine ou le plant délicatement","Il recouvre doucement avec la terre","Il arrose avec un petit arrosoir","Il donne un nom à sa plante et la marque avec un bâton"],variante:"Version herbes aromatiques : basilic, menthe, ciboulette — facile et rapide à pousser. Version fleurs : tournesol ou capucine. Version mini potager : tomates cerises.",benefice:"Développe l\'autonomie, la motricité fine et le sens des responsabilités à long terme.",securite:"Activité toujours accompagnée. Éviter les outils tranchants pour les plus petits."},
  {id:"JJ12",titre:"Le grand chef du jardin",lieu:"Jardin",duree:"20-30 min",intensite:"Modérée",objectif:"initiative, confiance en soi, leadership",materiel:"aucun",nbJ:"2-5",consigne:"C\'est toi le chef du jardin aujourd\'hui ! Tu décides du chemin, des défis et des aventures !",etapes:["Désignez un Chef du Jardin pour la séance","Il choisit le premier jeu ou défi","Il donne les consignes aux autres joueurs","Il peut inventer des obstacles ou des missions","Changez de chef toutes les 5-10 minutes","Chaque enfant doit avoir son tour"],variante:"Version chef pirate : le jardin est une île au trésor. Version chef explorateur : découvrir et nommer chaque recoin du jardin.",benefice:"Développe l\'initiative, la confiance en soi et le sens du leadership bienveillant.",securite:"Alterner les rôles pour que chaque enfant participe équitablement."},
  {id:"JP01",titre:"Parcours du petit aventurier",lieu:"Parc",duree:"15-20 min",intensite:"Modérée",objectif:"coordination, équilibre, confiance",materiel:"bancs, lignes au sol, bordures naturelles",nbJ:"1-4",consigne:"Le parc devient un terrain d\'aventure ! Utilise tout ce que tu trouves comme obstacle.",etapes:["Repérez ensemble les éléments du parc utilisables : bancs, bordures, arbres, lignes au sol","Créez un enchaînement : marcher sur la bordure, contourner l\'arbre, passer sous le banc, sauter d\'un repère à l\'autre","Expliquez le parcours en le mimant","Chacun le fait à son rythme","Modifiez le parcours après 3 passages"],variante:"Version pirate : traverser les mers sans se faire attraper. Version jungle : chaque zone est un pays différent. Version ninja : tout faire en silence.",benefice:"Développe la coordination, l\'équilibre et la confiance en ses capacités.",securite:"Vérifier la solidité de tous les appuis avant de commencer."},
  {id:"JP02",titre:"Chasse aux trésors du parc",lieu:"Parc",duree:"15-20 min",intensite:"Calme",objectif:"observation, curiosité, orientation",materiel:"petit panier ou sac",nbJ:"1-4",consigne:"Le parc cache des trésors partout ! Une feuille spéciale, un caillou rond, une plume, quelque chose qui sent bon...",etapes:["Donnez un petit panier à chaque enfant","Listez les trésors à trouver : feuille ronde, galet spécial, plume, quelque chose de brillant","L\'enfant explore librement le parc","À la fin, chacun présente ses trouvailles","Quel est ton trésor préféré ? Pourquoi ?"],variante:"Version couleurs : un trésor de chaque couleur. Version formes : chercher des formes dans la nature. Version libre : chacun choisit ses propres critères.",benefice:"Développe l\'observation, la curiosité et l\'orientation dans un espace public.",securite:"Pas d\'objets dangereux ni de déchets. Rester dans la zone délimitée et visible."},
  {id:"JP03",titre:"Le roi des toboggans",lieu:"Parc",duree:"15-20 min",intensite:"Modérée",objectif:"confiance, repérage spatial, motricité globale",materiel:"aire de jeux du parc",nbJ:"1-4",consigne:"Monter, attendre, glisser, revenir — et recommencer ! Mais toujours par le même chemin précis.",etapes:["Choisissez ensemble l\'aire de jeux","Montrez le chemin à emprunter : escalier → toboggan → retour par la gauche","L\'enfant monte calmement en tenant la rampe","Il attend en haut que la voie soit libre","Il glisse et revient par le chemin convenu","Inventez une histoire : tu glisses dans la rivière d\'aventure !"],variante:"Version chrono doux : combien de fois en 5 minutes ? Version mission : rapporter un objet imaginaire de chaque descente.",benefice:"Développe la confiance, le repérage spatial et la motricité globale.",securite:"Respecter les règles de sécurité de l\'aire de jeux. Ne pas pousser, attendre son tour."},
  {id:"JP04",titre:"Le détective nature au parc",lieu:"Parc",duree:"15-20 min",intensite:"Calme",objectif:"observation ciblée, comparaison, vocabulaire",materiel:"petite fiche imagée (facultatif)",nbJ:"1-4",consigne:"Enfilez votre casquette de détective ! Mission : trouver 3 feuilles différentes, 2 bâtons, 1 chose douce.",etapes:["Choisissez une mission adaptée au parc","3 feuilles de forme ou taille différente","2 bâtons de longueur différente","1 chose douce ET 1 chose rugueuse","L\'enfant part enquêter dans l\'espace proche","Il revient présenter ses preuves et expliquer les différences"],variante:"Version saison : chercher des signes de la saison actuelle. Version parc urbain : adapter avec du mobilier urbain. Version photo : photographier plutôt que ramasser.",benefice:"Développe l\'attention visuelle, la comparaison et le vocabulaire scientifique.",securite:"Adapter les missions aux éléments réellement présents dans ce parc."},
  {id:"JP05",titre:"Le jeu des statues au parc",lieu:"Parc",duree:"10-15 min",intensite:"Modérée",objectif:"contrôle corporel, réaction, équilibre",materiel:"musique sur téléphone ou signal voix",nbJ:"2-6",consigne:"On court, on danse, on s\'amuse — et quand l\'adulte crie STATUE, plus personne ne bouge !",etapes:["Les joueurs se déplacent librement dans l\'espace délimité","L\'adulte joue de la musique ou laisse courir","Au signal STATUE ! ou à l\'arrêt de la musique, tout le monde se fige","L\'adulte observe : qui a bougé après le signal ?","Reprenez et inventez des statues de plus en plus rigolotes"],variante:"Version statue animale : se figer en imitant un animal. Version statue rigolote : poser de la façon la plus drôle possible.",benefice:"Développe le contrôle corporel, la réactivité et l\'équilibre statique.",securite:"Espace bien délimité et dégagé d\'obstacles."},
  {id:"JP06",titre:"Lancer de précision au parc",lieu:"Parc",duree:"10-15 min",intensite:"Modérée",objectif:"adresse, coordination œil-main, viser",materiel:"balles souples, pommes de pin, seau ou cercle tracé",nbJ:"1-4",consigne:"Visez la cible ! Balles, pommes de pin ou cailloux plats — qui sera le plus précis ?",etapes:["Tracez un cercle au sol ou posez un seau comme cible","Tracez une ligne de tir à 1-2 mètres","Chaque joueur lance 3 fois","Comptez les points : dans la cible = 2 points, bord = 1 point","Reculez la ligne de tir à chaque round réussi"],variante:"Version main gauche : lancer avec la main non dominante. Version score : jouer en équipe et additionner les points.",benefice:"Développe la précision du lancer et la coordination œil-main.",securite:"Distance adaptée à l\'âge. Vérifier qu\'il n\'y a personne dans la trajectoire."},
  {id:"JP07",titre:"Mini chasse au trésor du parc",lieu:"Parc",duree:"15-20 min",intensite:"Modérée",objectif:"orientation spatiale, logique, lecture d\'indices",materiel:"3-4 indices simples, petit trésor",nbJ:"1-4",consigne:"Des indices mystérieux sont cachés dans le parc. Suivez-les jusqu\'au trésor final !",etapes:["Préparez 3 indices avant d\'arriver : dessins ou mots pointant vers des lieux du parc","Indice 1 au banc → pointe vers l\'arbre → pointe vers le toboggan → trésor !","Donnez le premier indice","L\'enfant lit (ou vous lisez) et part chercher","Le trésor final : autocollant, galet peint, petit jouet"],variante:"Version pirate : carte dessinée du parc. Version détective : photos des endroits au lieu de mots.",benefice:"Développe l\'orientation dans un espace public, la logique et la motivation.",securite:"Indices très simples et clairs. Rester dans la zone visible à tout moment."},
  {id:"JP08",titre:"Parcours pieds nus au parc",lieu:"Parc",duree:"10-15 min",intensite:"Calme",objectif:"proprioception, sensations plantaires, connexion nature",materiel:"herbe propre, sable si disponible",nbJ:"1-4",consigne:"Enlevez les chaussures et sentez le parc sous vos pieds ! Herbe, sable, terre — chaque texture est différente.",etapes:["Vérifiez d\'abord le sol : pas de verre, pas d\'objets pointus","L\'enfant enlève chaussures et chaussettes","Marchez lentement sur l\'herbe : qu\'est-ce que tu sens ?","Comparez avec le sable ou la terre si disponible","Fermez les yeux et devinez la surface"],variante:"Version yeux fermés avec l\'aide de l\'adulte pour sécuriser entièrement.",benefice:"Développe la proprioception, les sensations plantaires et le lien avec la nature.",securite:"Vérifier ABSOLUMENT le sol avant. Éviter les zones non entretenues."},
  {id:"JP09",titre:"Yoga du parc",lieu:"Parc",duree:"10-15 min",intensite:"Calme",objectif:"retour au calme, posture, respiration",materiel:"herbe ou tapis de sol",nbJ:"1-4",consigne:"Le parc est notre studio de yoga ! Des postures inspirées des animaux et de la nature qui nous entoure.",etapes:["Trouvez un espace d\'herbe agréable","L\'adulte annonce une posture en racontant une histoire","Arbre = debout sur un pied, bras vers le ciel, comme un arbre tropical","Chat = à 4 pattes, dos rond puis creux","Grenouille = accroupi jambes écartées","Papillon = assis, plantes des pieds ensemble, battre les genoux","Terminez allongés en étoile et respirez 5 fois profondément"],variante:"Version histoire yoga : raconter une aventure et les postures suivent le récit. Version respiration : inspirer en montant les bras, expirer en descendant.",benefice:"Développe la posture, la conscience corporelle et le retour au calme.",securite:"Aucune recherche de performance. Toutes les postures sont adaptées et jamais forcées."},
  {id:"JP10",titre:"Le grand chef du parc",lieu:"Parc",duree:"20-30 min",intensite:"Modérée",objectif:"initiative, confiance, leadership",materiel:"aucun",nbJ:"2-5",consigne:"Aujourd\'hui, c\'est toi le chef du parc ! Tu décides du chemin, des jeux et des aventures de la sortie.",etapes:["Désignez un Chef du Parc pour la séance","Il choisit par quel jeu on commence","Il peut inventer des missions : Allons toucher le grand arbre ! Courons jusqu\'au banc !","Il donne les consignes aux autres joueurs","Changez de chef toutes les 5-10 minutes","Chaque enfant doit avoir son tour"],variante:"Version capitaine : le parc est un navire et chaque zone est une île. Version explorateur : nommer et découvrir chaque recoin du parc.",benefice:"Développe l\'initiative, la confiance en soi et le sens du collectif.",securite:"Alterner les rôles pour que chaque enfant ait sa chance. Rester dans la zone visible."},
  {id:"JPL01",titre:"Parcours du petit explorateur",lieu:"Plage",duree:"15-20 min",intensite:"Modérée",objectif:"équilibre, coordination, confiance",materiel:"serviettes, seaux, coquillages, lignes dans le sable",nbJ:"1-4",consigne:"La plage devient ton île aventure ! Crée un parcours avec tout ce que tu trouves.",etapes:["Créez le parcours ensemble : ligne tracée dans le sable à marcher, seau à sauter par-dessus, serviette à contourner, sable mou puis sable dur","Expliquez le parcours en le mimant","Chacun le fait à son rythme","Ajoutez un obstacle après chaque réussite","Inventez une histoire : traverser l\'île sans tomber à l\'eau !"],variante:"Version pirate : chaque obstacle a un nom d\'île. Version jungle : chaque zone est un pays. Version ninja : tout faire en silence.",benefice:"Développe l\'équilibre, la coordination et la confiance en terrain instable.",securite:"Attention au soleil et au sol chaud. Éviter les heures chaudes (11h-15h)."},
  {id:"JPL02",titre:"Chasse aux trésors de la plage",lieu:"Plage",duree:"15-20 min",intensite:"Calme",objectif:"observation, curiosité, motricité fine",materiel:"petit seau ou panier",nbJ:"1-4",consigne:"La plage est couverte de trésors ! Coquillages, galets, plumes — qui trouvera les plus beaux ?",etapes:["Donnez un petit seau à chaque enfant","Listez les trésors à chercher : coquillage blanc, galet rond, plume, algue drôle, quelque chose qui brille","L\'enfant explore librement","À la fin, chacun présente ses trouvailles","Classez ensemble : plus petit, plus grand, plus beau, plus bizarre"],variante:"Version couleurs : un trésor de chaque couleur. Version formes : chercher des formes dans les coquillages. Version libre : chacun choisit ses propres critères.",benefice:"Développe l\'observation fine, la curiosité et la motricité fine.",securite:"Ne pas ramasser d\'objets coupants, de verre ou de déchets. Rester dans la zone visible."},
  {id:"JPL03",titre:"Mission eau de mer",lieu:"Plage",duree:"15-20 min",intensite:"Modérée",objectif:"motricité fine, coordination, endurance douce",materiel:"seaux, gobelets, arrosoir",nbJ:"1-4",consigne:"Remplis le château d\'eau de mer ! Transporte l\'eau depuis le bord de l\'eau jusqu\'au seau du château.",etapes:["Creusez un trou dans le sable (le château)","Placez un seau à remplir à côté","L\'enfant court jusqu\'à la mer, remplit son gobelet","Il revient en courant et verse dans le seau","Comptez combien de voyages pour remplir","Variez les contenants : gobelet, seau, arrosoir"],variante:"Version relais : plusieurs enfants en chaîne. Version cuillère : transport avec une grande cuillère. Qui sera le plus rapide ?",benefice:"Développe la motricité fine, l\'endurance douce et la persévérance.",securite:"Rester dans la zone peu profonde. Surveiller à tout moment près de l\'eau."},
  {id:"JPL04",titre:"Le jardin des animaux marins",lieu:"Plage",duree:"10-15 min",intensite:"Modérée",objectif:"schéma corporel, imagination, déplacement varié",materiel:"aucun",nbJ:"1-4",consigne:"La plage est peuplée d\'animaux marins ! À toi de les imiter pour te déplacer.",etapes:["L\'adulte annonce un animal marin","Crabe = marcher de côté, accroupi, pinces en l\'air","Étoile de mer = étendu au sol, bouger doucement les bras et jambes","Tortue = à 4 pattes, très lentement","Poisson = ondulations du corps, bras le long","Dauphin = sauter et plonger vers l\'avant","L\'enfant se déplace comme l\'animal annoncé"],variante:"Version devinette : l\'enfant mime, l\'adulte devine. Version relais : course entre zones en changeant d\'animal.",benefice:"Développe le schéma corporel et la variété des déplacements.",securite:"Respecter la fatigue. Éviter les heures chaudes."},
  {id:"JPL05",titre:"Land art sable",lieu:"Plage",duree:"15-25 min",intensite:"Calme",objectif:"créativité, patience, motricité fine",materiel:"coquillages, algues, galets, sable",nbJ:"1-4",consigne:"Le sable est ta toile et la plage ton atelier ! Crée une œuvre avec les trésors de la mer.",etapes:["Ramassez ensemble des matériaux naturels : coquillages, galets, algues, bois flotté","Choisissez un espace de sable plat comme toile","Créez une forme : étoile de mer géante, poisson, bateau, mandala","Décorez avec les matériaux collectés","Prenez une photo souvenir avant que la mer emporte tout !"],variante:"Version prénom : écrire son prénom en coquillages. Version château décoré : décorer les tours avec des coquillages. Version mandala : cercles de sable avec matériaux colorés.",benefice:"Développe la créativité, la patience et la connexion à la nature.",securite:"Utiliser uniquement ce qui est déjà sur la plage. Pas de cueillette."},
  {id:"JPL06",titre:"Plage sensorielle",lieu:"Plage",duree:"15-20 min",intensite:"Calme",objectif:"exploration sensorielle, vocabulaire, curiosité",materiel:"aucun",nbJ:"1-4",consigne:"Explorez la plage avec tous vos sens ! Trouvez quelque chose de doux, de rugueux, de froid, d\'humide...",etapes:["L\'adulte annonce une sensation","Doux = sable fin sec, duvet d\'oiseau","Rugueux = gros galet, coquille d\'huître","Froid = eau de mer, sable à l\'ombre","Humide = sable mouillé, algue fraîche","Léger = plume, coquille fine","L\'enfant cherche et revient montrer"],variante:"Version yeux fermés avec aide de l\'adulte. Version classement : trier les trouvailles du plus doux au plus rugueux.",benefice:"Développe la discrimination sensorielle et le vocabulaire des textures.",securite:"Attention aux objets piquants et aux méduses échouées. Toujours vérifier."},
  {id:"JPL07",titre:"Parcours pieds nus plage",lieu:"Plage",duree:"10-15 min",intensite:"Calme",objectif:"proprioception, sensations plantaires, équilibre",materiel:"sable sec, sable mouillé, galets doux",nbJ:"1-4",consigne:"Marchez pieds nus sur les différentes textures de la plage — chaque zone est une nouvelle sensation !",etapes:["Délimitez un parcours traversant différentes zones","Sable sec et chaud","Sable mouillé et compact","Galets doux et ronds","Bord de l\'eau légèrement mouillé","Marchez lentement d\'une zone à l\'autre","À chaque zone : qu\'est-ce que tu sens ?"],variante:"Version yeux fermés avec l\'aide de l\'adulte pour sécuriser complètement.",benefice:"Développe la proprioception, les sensations plantaires et l\'équilibre sur terrain instable.",securite:"Vérifier la température du sable (très chaud en plein soleil). Éviter les zones avec coquillages pointus."},
  {id:"JPL08",titre:"Course brouette sur sable",lieu:"Plage",duree:"10-15 min",intensite:"Dynamique",objectif:"gainage, coopération, force des bras",materiel:"aucun",nbJ:"2-4",consigne:"L\'adulte tient les jambes, l\'enfant avance sur les mains dans le sable ! Plus difficile que sur le sol dur.",etapes:["L\'enfant se met à plat ventre sur le sable","L\'adulte tient doucement les chevilles","L\'enfant se soulève sur les mains, bras tendus","Avancez sur une courte distance : 2-3 mètres","Le sable rend l\'exercice plus difficile et plus drôle !"],variante:"Très courte distance pour les 3-4 ans. L\'adulte peut tenir aux hanches pour plus de sécurité.",benefice:"Renforce le gainage abdominal et les bras de façon ludique sur surface instable.",securite:"Faire très doucement et sur une courte distance. Le sable amortit les chutes."},
